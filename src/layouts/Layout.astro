---
import '../styles/global.css';
---
<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<script is:inline>
			(function () {
				const savedLang = localStorage.getItem('language') || 'es';
				document.documentElement.lang = savedLang;

				const savedTheme = localStorage.getItem('theme') || 'theme-emerald';
				const savedMode = localStorage.getItem('theme-mode') || 'dark';

				document.documentElement.classList.add(savedTheme);
				if (savedMode === 'light') {
					document.documentElement.classList.add('light');
				} else {
					document.documentElement.classList.remove('light');
				}
			})();
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/17442852.png" />
		
		<!-- Devicon & FontAwesome -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
		
		<!-- Google Fonts: Outfit (modern sans-serif) & JetBrains Mono (monospaced) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

		<!-- Metadatos SEO -->
		<meta name="generator" content={Astro.generator} />
		<title>Ignacio Trkmic Torres | Portfolio & AI Agent</title>
		<meta name="description" content="Portfolio web de Ignacio Trkmic Torres - Estudiante de Programación e Ingeniería en la UTN. Desarrollador Backend & Fullstack con integración de Inteligencia Artificial." />
		<meta name="keywords" content="Ignacio Trkmic Torres, Ignacio Torres, Portfolio, Desarrollador, Backend, NestJS, Angular, Java, Python, UTN, Programación, Inteligencia Artificial" />
		<meta name="author" content="Ignacio Trkmic Torres" />
		
		<!-- Open Graph / LinkedIn / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Ignacio Trkmic Torres | Portfolio & AI Agent" />
		<meta property="og:description" content="Desarrollador backend y estudiante de programación en la UTN Avellaneda. Conoce mis proyectos y habla con mi asistente de IA." />
		<meta property="og:image" content="/WhatsApp Image 2025-12-19 at 9.57.16 PM.jpeg" />
	</head>
	<body class="bg-black text-slate-300 font-sans selection:bg-emerald-500/25 selection:text-emerald-300">
		<slot />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
	}

	code, pre, .font-mono {
		font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', Courier, monospace !important;
	}

	/* Scrollbar Premium */
	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		background: #020617;
	}
	::-webkit-scrollbar-thumb {
		background: #022c22;
		border-radius: 4px;
		border: 2px solid #020617;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #047857;
	}
</style>
