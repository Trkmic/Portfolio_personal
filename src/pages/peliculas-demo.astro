---
import Layout from '../layouts/Layout.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import ThemeModeToggle from '../components/ThemeModeToggle.astro';
---

<Layout>
    <!-- Selector de Temas y Barra de Mandos -->
    <ThemeSwitcher />
    <!-- Toggle de Modo Claro/Oscuro -->
    <ThemeModeToggle />

    <!-- Efecto de Fondo Neon/Malla dinámico -->
    <div class="fixed inset-0 z-0 bg-black overflow-hidden pointer-events-none">
        <div class="absolute top-[10%] left-[20%] w-[400px] h-[400px] rounded-full bg-theme-primary/5 blur-[120px] transition-all duration-700"></div>
        <div class="absolute bottom-[20%] right-[10%] w-[500px] h-[500px] rounded-full bg-theme-secondary/5 blur-[150px] transition-all duration-700"></div>
    </div>

    <main class="relative z-10 max-w-4xl mx-auto px-6 pt-32 pb-12 flex flex-col gap-8 min-h-screen text-slate-300 font-sans">
        
        <!-- Botón Volver y Header -->
        <div class="flex flex-col gap-4">
            <a href="/" class="self-start text-xs font-mono font-bold text-theme-primary hover:text-theme-primary/80 transition-colors uppercase tracking-wider flex items-center gap-2">
                <i class="fa-solid fa-arrow-left"></i>
                <span data-demo-i18n="back_btn">← Volver al inicio</span>
            </a>
            
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-theme-secondary/30 pb-4">
                <div>
                    <h1 class="text-3xl font-extrabold text-white tracking-tight" data-demo-i18n="page_title">
                        Simulador de Sistema de Gestión de Películas
                    </h1>
                    <p class="text-theme-secondary text-sm font-mono mt-1" data-demo-i18n="page_subtitle">
                        Portabilidad interactiva de la lógica de procesamiento de datos Python a la Web
                    </p>
                </div>
                <div class="flex gap-2 font-mono text-[10px]">
                    <span class="bg-theme-primary/10 text-theme-primary border border-theme-primary/30 px-3 py-1 rounded-full font-bold uppercase tracking-wide">
                        Python 3.13
                    </span>
                    <span class="bg-slate-900 text-slate-400 border border-slate-800 px-3 py-1 rounded-full font-bold uppercase tracking-wide">
                        Refactored & Modular
                    </span>
                </div>
            </div>
        </div>

        <!-- Estructura del Proyecto Modular Python -->
        <section class="bg-slate-950/40 p-6 rounded-2xl border border-theme-secondary/25 hover:border-theme-primary/25 transition-all duration-300 shadow-[inset_0_0_15px_var(--theme-glow)]">
            <h2 class="text-lg font-bold mb-4 text-theme-primary font-mono tracking-wide uppercase flex items-center gap-2">
                <i class="fa-solid fa-folder-tree text-sm"></i>
                <span data-demo-i18n="python_structure">Arquitectura del Proyecto Python</span>
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 font-mono text-[11px] text-slate-400">
                <div class="bg-black/50 p-4 rounded-xl border border-slate-900 flex flex-col gap-1.5 relative overflow-hidden group hover:border-theme-primary/30 transition-all duration-300">
                    <h3 class="text-white font-bold border-b border-slate-800 pb-1 flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-theme-primary"></span>
                        peliculas.py & main.py
                    </h3>
                    <p class="text-[10px] text-slate-500 italic">Controlador y núcleo de negocio</p>
                    <p>Gestiona el flujo principal (`dar_alta`, `modificar_pelicula`, `eliminar_pelicula`) y controla los submenús de navegación por consola.</p>
                </div>
                
                <div class="bg-black/50 p-4 rounded-xl border border-slate-900 flex flex-col gap-1.5 relative overflow-hidden group hover:border-theme-primary/30 transition-all duration-300">
                    <h3 class="text-white font-bold border-b border-slate-800 pb-1 flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-theme-secondary"></span>
                        validaciones.py
                    </h3>
                    <p class="text-[10px] text-slate-500 italic">Verificación de datos</p>
                    <p>Filtra y sanea inputs: IDs autoincrementales, año de lanzamiento, géneros (insensible a mayúsculas), plataformas sin números y respuestas Si/No.</p>
                </div>

                <div class="bg-black/50 p-4 rounded-xl border border-slate-900 flex flex-col gap-1.5 relative overflow-hidden group hover:border-theme-primary/30 transition-all duration-300">
                    <h3 class="text-white font-bold border-b border-slate-800 pb-1 flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                        funciones_*.py
                    </h3>
                    <p class="text-[10px] text-slate-500 italic">Procesamiento y archivos</p>
                    <p>Submódulos especializados en persistencia CSV (`archivo`), cálculo estadístico de promedios/porcentajes (`matematicas`) y formateo matricial de texto (`mostrar`).</p>
                </div>
            </div>
        </section>

        <!-- Contenedor Principal de la App Interactiva -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- Columna Izquierda (8 cols): Aplicación interactiva -->
            <div class="lg:col-span-8 flex flex-col gap-6">
                
                <!-- Pestañas de Navegación -->
                <div class="flex border-b border-slate-900 gap-2 font-mono text-xs">
                    <button id="tab-list" class="px-4 py-2 border-b-2 border-theme-primary text-white font-bold transition-all bg-theme-primary/5 rounded-t-lg cursor-pointer">
                        🎬 <span data-demo-i18n="tab_movies">Películas</span>
                    </button>
                    <button id="tab-manage" class="px-4 py-2 border-b-2 border-transparent text-slate-500 hover:text-slate-300 hover:border-slate-800 transition-all cursor-pointer">
                        ⚙️ <span data-demo-i18n="tab_manage">Gestionar</span>
                    </button>
                    <button id="tab-query" class="px-4 py-2 border-b-2 border-transparent text-slate-500 hover:text-slate-300 hover:border-slate-800 transition-all cursor-pointer">
                        🔍 <span data-demo-i18n="tab_query">Consultas</span>
                    </button>
                    <button id="tab-stats" class="px-4 py-2 border-b-2 border-transparent text-slate-500 hover:text-slate-300 hover:border-slate-800 transition-all cursor-pointer">
                        📊 <span data-demo-i18n="tab_stats">Estadísticas</span>
                    </button>
                </div>

                <!-- Contenido de Pestañas -->
                <div class="bg-slate-950/40 p-6 rounded-2xl border border-theme-secondary/20 shadow-md min-h-[400px]">
                    
                    <!-- Caja de Excepciones Similares a validaciones.py -->
                    <div id="demo-error-alert" class="hidden mb-6 p-4 rounded-xl border border-rose-500/30 bg-rose-950/20 text-rose-400 font-mono text-xs relative animate-pulse">
                        <div class="font-bold flex items-center gap-2 mb-1">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <span id="error-title">ValidationError</span>
                        </div>
                        <p id="error-message">Detalle del error de validación...</p>
                    </div>

                    <!-- Pestaña 1: Lista de Películas -->
                    <div id="content-list" class="block">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-sm font-bold text-slate-400 font-mono uppercase tracking-wider" data-demo-i18n="list_title">
                                Películas en la Base de Datos (CSV)
                            </h3>
                            <span id="movies-count" class="text-xs font-mono text-theme-primary bg-theme-primary/10 border border-theme-primary/20 px-2 py-0.5 rounded-full font-bold">
                                0 Películas
                            </span>
                        </div>
                        
                        <!-- Tabla Neon Receptiva -->
                        <div class="overflow-x-auto border border-slate-900 rounded-xl bg-black/30">
                            <table class="w-full text-left border-collapse font-mono text-[11px] text-slate-300">
                                <thead>
                                    <tr class="border-b border-slate-900 bg-slate-950/80 text-white font-bold text-[10px] uppercase tracking-wider">
                                        <th class="p-3">ID</th>
                                        <th class="p-3">Título</th>
                                        <th class="p-3">Género</th>
                                        <th class="p-3">Año</th>
                                        <th class="p-3 text-center">Duración</th>
                                        <th class="p-3 text-center">ATP</th>
                                        <th class="p-3">Plataformas</th>
                                    </tr>
                                </thead>
                                <tbody id="movies-table-body">
                                    <!-- Inyectado dinámicamente -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Pestaña 2: Gestionar (Alta/Modificación/Eliminación) -->
                    <div id="content-manage" class="hidden flex flex-col gap-6">
                        
                        <!-- Panel de Selección de Acción -->
                        <div class="flex gap-2 font-mono text-xs">
                            <button id="btn-action-add" class="flex-1 py-2 rounded-lg border border-theme-primary/30 bg-theme-primary/10 text-white font-bold cursor-pointer text-center">
                                ➕ Alta
                            </button>
                            <button id="btn-action-edit" class="flex-1 py-2 rounded-lg border border-slate-800 bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center">
                                ✏️ Modificar
                            </button>
                            <button id="btn-action-delete" class="flex-1 py-2 rounded-lg border border-slate-800 bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center">
                                ❌ Eliminar
                            </button>
                        </div>

                        <!-- Sección de Formularios -->
                        <div class="border border-slate-900 p-5 rounded-2xl bg-black/40">
                            
                            <!-- Formulario A: Dar Alta -->
                            <form id="form-add-movie" class="block space-y-4 font-mono text-xs">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="space-y-1.5">
                                        <label for="add-title" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="lbl_title">Título de la Película</label>
                                        <input type="text" id="add-title" required placeholder="Ej: Matrix" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50 transition-colors" />
                                    </div>
                                    <div class="space-y-1.5">
                                        <label for="add-genre" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="lbl_genre">Género</label>
                                        <select id="add-genre" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50">
                                            <!-- Géneros cargados por JS -->
                                        </select>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <div class="space-y-1.5">
                                        <label for="add-year" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="lbl_year">Año de Lanzamiento</label>
                                        <input type="number" id="add-year" required placeholder="Ej: 1999" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                    </div>
                                    <div class="space-y-1.5">
                                        <label for="add-duration" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="lbl_duration">Duración (Minutos)</label>
                                        <input type="number" id="add-duration" required placeholder="Ej: 136" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                    </div>
                                    <div class="space-y-1.5 flex flex-col justify-end pb-3">
                                        <label class="flex items-center gap-2 cursor-pointer text-slate-300">
                                            <input type="checkbox" id="add-atp" class="accent-theme-primary w-4 h-4" />
                                            <span class="font-bold uppercase tracking-wider" data-demo-i18n="lbl_atp">¿Es Apta Todo Público?</span>
                                        </label>
                                    </div>
                                </div>

                                <div class="space-y-1.5">
                                    <label for="add-platforms" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="lbl_platforms">Plataformas de Distribución (Separadas por guión "-")</label>
                                    <input type="text" id="add-platforms" required placeholder="Ej: Netflix-Disney+-Amazon Prime" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                    <span class="text-[9px] text-slate-600 block" data-demo-i18n="platforms_note">⚠️ Nota: Las plataformas no deben contener números (validado por validaciones.py).</span>
                                </div>

                                <button type="submit" class="w-full bg-theme-primary hover:bg-theme-primary/95 text-black font-black py-3 rounded-xl transition-all uppercase tracking-tight flex justify-center items-center gap-2 cursor-pointer shadow-[0_0_12px_var(--theme-glow)]">
                                    <i class="fa-solid fa-circle-plus"></i> <span data-demo-i18n="btn_submit_add">Registrar Nueva Película</span>
                                </button>
                            </form>

                            <!-- Formulario B: Modificar -->
                            <form id="form-edit-movie" class="hidden space-y-4 font-mono text-xs">
                                <div class="space-y-2 pb-3 border-b border-slate-900">
                                    <label for="edit-search-title" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="edit_search_lbl">Paso 1: Ingrese el Título de la película a modificar</label>
                                    <div class="flex gap-2">
                                        <input type="text" id="edit-search-title" placeholder="Ej: Titanic" class="flex-1 bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                        <button type="button" id="btn-edit-load" class="bg-slate-900 border border-slate-850 hover:border-theme-primary/40 text-slate-200 px-5 rounded-xl uppercase tracking-wider cursor-pointer">Buscar</button>
                                    </div>
                                </div>

                                <div id="edit-fields-group" class="hidden space-y-4">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="space-y-1.5">
                                            <label for="edit-title" class="text-slate-400 uppercase font-bold tracking-wider">Nuevo Título</label>
                                            <input type="text" id="edit-title" required class="w-full bg-black border border-slate-855 rounded-xl p-3 text-slate-200 focus:outline-none" />
                                        </div>
                                        <div class="space-y-1.5">
                                            <label for="edit-genre" class="text-slate-400 uppercase font-bold tracking-wider">Género</label>
                                            <select id="edit-genre" class="w-full bg-black border border-slate-855 rounded-xl p-3 text-slate-200 focus:outline-none">
                                                <!-- Cargado por JS -->
                                            </select>
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                        <div class="space-y-1.5">
                                            <label for="edit-year" class="text-slate-400 uppercase font-bold tracking-wider">Año de Lanzamiento</label>
                                            <input type="number" id="edit-year" required class="w-full bg-black border border-slate-855 rounded-xl p-3 text-slate-200 focus:outline-none" />
                                        </div>
                                        <div class="space-y-1.5">
                                            <label for="edit-duration" class="text-slate-400 uppercase font-bold tracking-wider">Duración (Minutos)</label>
                                            <input type="number" id="edit-duration" required class="w-full bg-black border border-slate-855 rounded-xl p-3 text-slate-200 focus:outline-none" />
                                        </div>
                                        <div class="space-y-1.5 flex flex-col justify-end pb-3">
                                            <label class="flex items-center gap-2 cursor-pointer text-slate-300">
                                                <input type="checkbox" id="edit-atp" class="accent-theme-primary w-4 h-4" />
                                                <span class="font-bold uppercase tracking-wider">Apta Todo Público</span>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="space-y-1.5">
                                        <label for="edit-platforms" class="text-slate-400 uppercase font-bold tracking-wider">Plataformas (Separadas por guión "-")</label>
                                        <input type="text" id="edit-platforms" required class="w-full bg-black border border-slate-855 rounded-xl p-3 text-slate-200 focus:outline-none" />
                                    </div>

                                    <button type="submit" class="w-full bg-theme-primary hover:bg-theme-primary/95 text-black font-black py-3 rounded-xl transition-all uppercase tracking-tight flex justify-center items-center gap-2 cursor-pointer shadow-[0_0_12px_var(--theme-glow)]">
                                        <i class="fa-solid fa-floppy-disk"></i> <span data-demo-i18n="btn_submit_edit">Guardar Cambios</span>
                                    </button>
                                </div>
                            </form>

                            <!-- Formulario C: Eliminar -->
                            <form id="form-delete-movie" class="hidden space-y-4 font-mono text-xs">
                                <label for="delete-search-title" class="text-slate-400 uppercase font-bold tracking-wider" data-demo-i18n="delete_search_lbl">Ingrese el Título de la película a eliminar</label>
                                <div class="flex gap-2">
                                    <input type="text" id="delete-search-title" placeholder="Ej: Matrix" class="flex-1 bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                    <button type="submit" class="bg-rose-600 hover:bg-rose-500 text-white font-black px-6 rounded-xl uppercase tracking-wider cursor-pointer">Eliminar</button>
                                </div>
                            </form>

                        </div>
                    </div>

                    <!-- Pestaña 3: Consultas / Filtrado -->
                    <div id="content-query" class="hidden flex flex-col gap-6 font-mono text-xs">
                        
                        <!-- Panel de Tipo de Búsqueda -->
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                            <button id="query-tab-title" class="p-2.5 border border-theme-primary/30 rounded-xl bg-theme-primary/5 text-white font-bold cursor-pointer text-center">
                                🔍 Título
                            </button>
                            <button id="query-tab-genre" class="p-2.5 border border-slate-800 rounded-xl bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center">
                                🎭 Género
                            </button>
                            <button id="query-tab-platform" class="p-2.5 border border-slate-800 rounded-xl bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center">
                                🌐 Plataforma
                            </button>
                            <button id="query-tab-atp" class="p-2.5 border border-slate-800 rounded-xl bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center">
                                🚸 ATP
                            </button>
                        </div>

                        <!-- Filtros Ejecutables -->
                        <div class="border border-slate-900 p-5 rounded-2xl bg-black/40 space-y-4">
                            
                            <!-- Filtro A: Por Título -->
                            <div id="filter-code-title" class="block space-y-3">
                                <label for="query-title-input" class="text-[10px] font-bold uppercase text-slate-500 tracking-wider">Buscar por título (Insensible a mayúsculas/minúsculas)</label>
                                <div class="flex gap-2">
                                    <input type="text" id="query-title-input" placeholder="Ej: matrix" class="flex-1 bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                    <button id="btn-filter-title" class="bg-theme-primary hover:bg-theme-primary/95 text-black font-black px-5 rounded-xl uppercase tracking-wider cursor-pointer">Buscar</button>
                                </div>
                            </div>

                            <!-- Filtro B: Por Género -->
                            <div id="filter-code-genre" class="hidden space-y-3">
                                <label for="query-genre-input" class="text-[10px] font-bold uppercase text-slate-500 tracking-wider">Filtrar por género de película</label>
                                <div class="flex gap-2">
                                    <select id="query-genre-input" class="flex-1 bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50">
                                        <!-- Cargado dinámicamente -->
                                    </select>
                                    <button id="btn-filter-genre" class="bg-theme-primary hover:bg-theme-primary/95 text-black font-black px-5 rounded-xl uppercase tracking-wider cursor-pointer">Filtrar</button>
                                </div>
                            </div>

                            <!-- Filtro C: Por Plataforma -->
                            <div id="filter-code-platform" class="hidden space-y-3">
                                <label for="query-platform-input" class="text-[10px] font-bold uppercase text-slate-500 tracking-wider">Buscar por Plataforma (Contiene la palabra)</label>
                                <div class="flex gap-2">
                                    <input type="text" id="query-platform-input" placeholder="Ej: disney" class="flex-1 bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none focus:border-theme-primary/50" />
                                    <button id="btn-filter-platform" class="bg-theme-primary hover:bg-theme-primary/95 text-black font-black px-5 rounded-xl uppercase tracking-wider cursor-pointer">Filtrar</button>
                                </div>
                            </div>

                            <!-- Filtro D: Por ATP -->
                            <div id="filter-code-atp" class="hidden space-y-3">
                                <label class="text-[10px] font-bold uppercase text-slate-500 tracking-wider">Filtrar películas Aptas para Todo Público</label>
                                <div class="flex gap-4">
                                    <button id="btn-filter-atp-true" class="flex-1 bg-theme-primary/10 border border-theme-primary/30 text-theme-primary font-bold py-3 rounded-xl hover:bg-theme-primary/20 transition cursor-pointer">Apta Todo Público (True)</button>
                                    <button id="btn-filter-atp-false" class="flex-1 bg-slate-900 border border-slate-800 text-slate-400 py-3 rounded-xl hover:bg-slate-800 transition cursor-pointer">Mayores de Edad (False)</button>
                                </div>
                            </div>

                            <!-- Caja de Resultados de Filtros -->
                            <div class="border-t border-slate-900 pt-4 mt-2">
                                <h4 class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-3">Resultados del Filtro</h4>
                                <div id="query-results-box" class="flex flex-col gap-2 max-h-[220px] overflow-y-auto pr-2">
                                    <p class="text-xs italic text-slate-600">No se ha ejecutado ninguna consulta aún.</p>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Pestaña 4: Estadísticas e Informes -->
                    <div id="content-stats" class="hidden flex flex-col gap-6 font-mono text-xs">
                        
                        <!-- Panel de Resúmenes Matemáticos -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-black/50 p-4 rounded-xl border border-slate-900 flex flex-col gap-1">
                                <span class="text-slate-500 text-[10px] uppercase font-bold tracking-wider">Promedio de Duración</span>
                                <p class="text-2xl font-bold text-theme-primary" id="stat-avg-duration">0 min</p>
                                <p class="text-[9px] text-slate-600 mt-1">Cálculo acumulativo sobre duración total.</p>
                            </div>
                            <div class="bg-black/50 p-4 rounded-xl border border-slate-900 flex flex-col gap-1">
                                <span class="text-slate-500 text-[10px] uppercase font-bold tracking-wider">Promedio de Año de Lanzamiento</span>
                                <p class="text-2xl font-bold text-theme-primary" id="stat-avg-year">0</p>
                                <p class="text-[9px] text-slate-600 mt-1">Año medio de la colección de películas.</p>
                            </div>
                        </div>

                        <!-- Porcentajes y Generación de Reportes JSON -->
                        <div class="border border-slate-900 p-5 rounded-2xl bg-black/40 space-y-4">
                            <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider">Reportes Estadísticos Especiales</h3>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-end">
                                <div class="space-y-1.5">
                                    <label for="stat-select-genre" class="text-[10px] font-bold uppercase text-slate-500 tracking-wider">Ver Porcentaje de un Género</label>
                                    <select id="stat-select-genre" class="w-full bg-black border border-slate-800 rounded-xl p-3 text-slate-200 focus:outline-none">
                                        <!-- Géneros -->
                                    </select>
                                </div>
                                <div class="p-3 bg-slate-900/40 border border-slate-900 rounded-xl flex justify-between items-center h-[46px]">
                                    <span class="text-slate-400">Porcentaje:</span>
                                    <strong class="text-theme-primary text-base" id="stat-genre-percent">0.00%</strong>
                                </div>
                            </div>

                            <div class="p-4 bg-slate-900/20 border border-slate-900 rounded-xl space-y-2">
                                <div class="flex justify-between items-center text-[10px] text-slate-400 uppercase font-bold font-mono">
                                    <span>Porcentaje ATP vs No ATP</span>
                                </div>
                                <div class="flex items-center gap-2 h-4 rounded-full bg-slate-950 overflow-hidden text-[9px] font-bold text-black font-mono">
                                    <div id="bar-atp-true" class="h-full bg-theme-primary flex items-center justify-center transition-all duration-500" style="width: 50%">ATP</div>
                                    <div id="bar-atp-false" class="h-full bg-theme-secondary flex items-center justify-center transition-all duration-500 text-white" style="width: 50%">MAYORES</div>
                                </div>
                                <div class="flex justify-between text-[9px] text-slate-500 font-mono">
                                    <span>ATP: <strong class="text-slate-300" id="stat-atp-true-lbl">50.00%</strong></span>
                                    <span>Mayores: <strong class="text-slate-300" id="stat-atp-false-lbl">50.00%</strong></span>
                                </div>
                            </div>

                            <!-- Botón e Informe JSON (Generación de JSON generos) -->
                            <div class="border-t border-slate-900 pt-4 space-y-3">
                                <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3">
                                    <div>
                                        <h4 class="text-white font-bold">Exportar JSON por Género</h4>
                                        <p class="text-[9.5px] text-slate-500 font-mono mt-0.5">Simula la escritura del archivo `peliculas_generos.json` (funciones_mostrar.py).</p>
                                    </div>
                                    <button id="btn-generate-json" class="bg-theme-primary hover:bg-theme-primary/95 text-black font-black px-4 py-2 rounded-lg transition-transform hover:scale-[1.02] uppercase tracking-wide cursor-pointer text-[10px]">
                                        📁 Generar Reporte JSON
                                    </button>
                                </div>

                                <div id="json-output-box" class="hidden border border-theme-primary/20 bg-black/60 p-4 rounded-xl font-mono text-[10px] text-emerald-400/90 max-h-[160px] overflow-y-auto animate-fade-in whitespace-pre">
                                    <!-- Inyectado dinámicamente -->
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Columna Derecha (4 cols): Consola Terminal Python -->
            <div class="lg:col-span-4 flex flex-col gap-6">
                <div class="bg-black border border-slate-900 rounded-2xl overflow-hidden shadow-2xl relative">
                    <!-- Cabecera de Consola -->
                    <div class="bg-slate-950 px-4 py-3 border-b border-slate-900 flex justify-between items-center">
                        <div class="flex items-center gap-1.5">
                            <span class="w-3 h-3 rounded-full bg-rose-500"></span>
                            <span class="w-3 h-3 rounded-full bg-amber-500"></span>
                            <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
                        </div>
                        <span class="text-[10px] font-mono text-slate-500">main.py Python Console</span>
                        <i class="fa-brands fa-python text-xs text-slate-700"></i>
                    </div>

                    <!-- Cuerpo de Consola -->
                    <div class="p-4 font-mono text-[10px] leading-relaxed text-emerald-400/90 h-[420px] overflow-y-auto bg-slate-950/70" id="terminal-content">
                        <span class="text-slate-600">// Haz click en "Ejecutar Script Python" para simular la ejecución e impresión matricial...</span>
                        <div class="mt-3 text-slate-400" id="terminal-cursor-line">
                            <span class="text-theme-primary">Ignacio-MacBook-Pro:~$</span> python main.py
                            <button id="btn-run-terminal" class="mt-4 block bg-theme-primary hover:bg-theme-primary/90 text-black font-extrabold px-4 py-2 rounded-lg transition-transform hover:scale-[1.03] uppercase cursor-pointer text-xs">
                                <i class="fa-solid fa-play mr-1.5"></i> Ejecutar Script Python
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </main>
</Layout>

<script>
    // ==========================================
    // Lógica Interactiva en Javascript (Cliente)
    // ==========================================

    const lista_generos = [
        "Acción", "Aventura","Animación", "Biográfico", "Comedia", "Comedia romántica", "Comedia dramática", "Crimen", 
        "Documental", "Drama", "Fantasía", "Histórico", "Infantil", "Musical", "Misterio", "Policíaco", "Romance", "Ciencia ficción", "Suspenso", "Terror", "Western", 
        "Bélico", "Deportivo", "Noir", "Experimental", "Familiar", "Superhéroes", "Espionaje", "Artes marciales", "Fantástico", "Catástrofe", "Melodrama", "Erótico", 
        "Cine independiente", "Zombies", "Vampiros", "Cyberpunk", "Steampunk", "Distopía", "Utopía", "Road Movie", "Docuficción", "Mockumentary", "Gótico", "Slasher", 
        "Adolescente", "Culto", "Maravilloso"
    ];

    class Pelicula {
        constructor(id, titulo, genero, anio_lanzamiento, duracion, atp, plataforma) {
            // Validaciones equivalentes a validaciones.py
            if (!titulo || titulo.trim().length <= 1 || titulo.trim().length >= 50) {
                throw {
                    type: 'ValueError',
                    message: 'El título de la película debe tener entre 2 y 48 caracteres.'
                };
            }
            // Género debe coincidir insensible
            const matchGen = lista_generos.find(g => g.toLowerCase() === genero.toLowerCase());
            if (!matchGen) {
                throw {
                    type: 'ValueError',
                    message: 'El género ingresado no es válido. Debe elegir uno de la lista oficial.'
                };
            }
            const currentYear = new Date().getFullYear();
            if (anio_lanzamiento < 1888 || anio_lanzamiento > currentYear) {
                throw {
                    type: 'ValueError',
                    message: `El año de lanzamiento debe estar entre 1888 y ${currentYear}.`
                };
            }
            if (duracion <= 1) {
                throw {
                    type: 'ValueError',
                    message: 'La duración debe ser mayor a 1 minuto.'
                };
            }
            // Plataformas sin números
            const hasNum = /[0-9]/.test(plataforma);
            if (hasNum) {
                throw {
                    type: 'ValueError',
                    message: 'Debe ingresar plataformas válidas que no contengan caracteres numéricos.'
                };
            }

            this.id = id;
            this.titulo = titulo.trim();
            this.genero = matchGen; // Guarda con la capitalización de la lista
            this.año_lanzamiento = anio_lanzamiento;
            this.duracion = duracion;
            this.atp = atp;
            this.plataforma = plataforma.trim();
        }
    }

    // Inicializar películas simulando peliculass.csv
    const peliculas = [
        new Pelicula(10, "Titanic", "Romance", 1997, 195, false, "Disney+-Amazon Prime"),
        new Pelicula(65, "Los 8 más odiados", "Western", 2015, 187, false, "Netflix"),
        new Pelicula(75, "Vengadores: endgame", "Superhéroes", 2019, 181, true, "Disney+"),
        new Pelicula(41, "El lobo de wall street", "Biográfico", 2013, 180, false, "Netflix-Amazon Prime"),
        new Pelicula(73, "El señor de los anillos: las dos torres", "Fantasía", 2002, 179, false, "Amazon Prime"),
        new Pelicula(26, "Corazón valiente", "Histórico", 1995, 178, false, "Netflix-Amazon Prime"),
        new Pelicula(19, "El señor de los anillos: la comunidad del anillo", "Fantasía", 2001, 178, true, "Amazon Prime"),
        new Pelicula(2, "El padrino", "Crimen", 1972, 175, false, "HBO Max-Amazon Prime"),
        new Pelicula(21, "Interestelar", "Ciencia ficción", 2014, 169, false, "Netflix-Amazon Prime"),
        new Pelicula(3, "Toy story", "Animación", 1995, 81, true, "Disney+")
    ];

    // ==========================================
    // UI Pestañas
    // ==========================================
    const tabs = {
        list: document.getElementById('tab-list'),
        manage: document.getElementById('tab-manage'),
        query: document.getElementById('tab-query'),
        stats: document.getElementById('tab-stats')
    };

    const sections = {
        list: document.getElementById('content-list'),
        manage: document.getElementById('content-manage'),
        query: document.getElementById('content-query'),
        stats: document.getElementById('content-stats')
    };

    function activateTab(tabName) {
        Object.keys(tabs).forEach(name => {
            const tabBtn = tabs[name];
            const section = sections[name];
            if (name === tabName) {
                tabBtn.className = "px-4 py-2 border-b-2 border-theme-primary text-white font-bold transition-all bg-theme-primary/5 rounded-t-lg cursor-pointer";
                section.classList.remove('hidden');
                section.classList.add('block');
            } else {
                tabBtn.className = "px-4 py-2 border-b-2 border-transparent text-slate-500 hover:text-slate-300 hover:border-slate-800 transition-all cursor-pointer";
                section.classList.remove('block');
                section.classList.add('hidden');
            }
        });
        hideError();
    }

    tabs.list.addEventListener('click', () => {
        activateTab('list');
        renderMoviesTable();
    });
    tabs.manage.addEventListener('click', () => {
        activateTab('manage');
        showManageAction('add');
    });
    tabs.query.addEventListener('click', () => {
        activateTab('query');
        activateQuerySub('title');
        runQueryTitle(); // buscar todo por defecto
    });
    tabs.stats.addEventListener('click', () => {
        activateTab('stats');
        calculateStatistics();
        const jsonBox = document.getElementById('json-output-box');
        if (jsonBox) jsonBox.classList.add('hidden'); // Ocultar JSON viejo
    });

    // ==========================================
    // UI Manejo de Errores (validaciones.py alerts)
    // ==========================================
    const errorAlert = document.getElementById('demo-error-alert');
    const errorTitle = document.getElementById('error-title');
    const errorMessage = document.getElementById('error-message');

    function showError(type, msg) {
        if (errorAlert && errorTitle && errorMessage) {
            errorTitle.textContent = type;
            errorMessage.textContent = msg;
            errorAlert.classList.remove('hidden');
            errorAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    }

    function hideError() {
        if (errorAlert) errorAlert.classList.add('hidden');
    }

    // ==========================================
    // Rellenar selectores de Géneros
    // ==========================================
    const selectors = ['add-genre', 'edit-genre', 'query-genre-input', 'stat-select-genre'];
    selectors.forEach(id => {
        const sel = document.getElementById(id) as HTMLSelectElement | null;
        if (sel) {
            sel.innerHTML = '';
            // Si es filtro o estadística, añadir opción vacía o por defecto
            if (id === 'query-genre-input') {
                const opt = document.createElement('option');
                opt.value = '';
                opt.textContent = 'Seleccionar género...';
                sel.appendChild(opt);
            }
            lista_generos.forEach(g => {
                const opt = document.createElement('option');
                opt.value = g;
                opt.textContent = g;
                sel.appendChild(opt);
            });
        }
    });

    // ==========================================
    // Listado de películas (Renderizado de Tabla)
    // ==========================================
    const tableBody = document.getElementById('movies-table-body');
    const moviesCountBadge = document.getElementById('movies-count');

    function renderMoviesTable() {
        if (!tableBody || !moviesCountBadge) return;
        moviesCountBadge.textContent = `${peliculas.length} Películas`;
        tableBody.innerHTML = '';

        if (peliculas.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-slate-500 italic">No hay películas registradas en el sistema.</td></tr>`;
            return;
        }

        // Ordenar por ID para consistencia visual
        const sorted = [...peliculas].sort((a, b) => a.id - b.id);

        sorted.forEach(m => {
            const tr = document.createElement('tr');
            tr.className = 'border-b border-slate-900 hover:bg-slate-900/20 transition-colors';
            tr.innerHTML = `
                <td class="p-3 text-slate-400 font-bold">${m.id}</td>
                <td class="p-3 text-white font-bold">${m.titulo}</td>
                <td class="p-3 text-theme-primary">${m.genero}</td>
                <td class="p-3">${m.año_lanzamiento}</td>
                <td class="p-3 text-center">${m.duracion} min</td>
                <td class="p-3 text-center">
                    <span class="px-2 py-0.5 rounded text-[9px] font-bold uppercase ${m.atp ? 'bg-emerald-950 text-emerald-400 border border-emerald-500/20' : 'bg-rose-950/40 text-rose-400 border border-rose-500/10'}">
                        ${m.atp ? 'Sí' : 'No'}
                    </span>
                </td>
                <td class="p-3 text-[10px] text-slate-400">${m.plataforma}</td>
            `;
            tableBody.appendChild(tr);
        });
    }

    // ==========================================
    // Pestaña Gestión: Sub-acciones (Alta/Mod/Del)
    // ==========================================
    const actionBtns = {
        add: document.getElementById('btn-action-add'),
        edit: document.getElementById('btn-action-edit'),
        delete: document.getElementById('btn-action-delete')
    };

    const actionForms = {
        add: document.getElementById('form-add-movie'),
        edit: document.getElementById('form-edit-movie'),
        delete: document.getElementById('form-delete-movie')
    };

    function showManageAction(actionName) {
        Object.keys(actionBtns).forEach(name => {
            const btn = actionBtns[name];
            const form = actionForms[name];
            if (name === actionName) {
                btn.className = "flex-1 py-2 rounded-lg border border-theme-primary/30 bg-theme-primary/10 text-white font-bold cursor-pointer text-center";
                form.classList.remove('hidden');
                form.classList.add('block');
            } else {
                btn.className = "flex-1 py-2 rounded-lg border border-slate-800 bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center";
                form.classList.remove('block');
                form.classList.add('hidden');
            }
        });
        hideError();
        // Reset forms
        actionForms.add.reset();
        actionForms.edit.reset();
        actionForms.delete.reset();
        document.getElementById('edit-fields-group').classList.add('hidden');
    }

    actionBtns.add.addEventListener('click', () => showManageAction('add'));
    actionBtns.edit.addEventListener('click', () => showManageAction('edit'));
    actionBtns.delete.addEventListener('click', () => showManageAction('delete'));

    // --- A. Dar Alta ---
    actionForms.add.addEventListener('submit', (e) => {
        e.preventDefault();
        hideError();

        const title = (document.getElementById('add-title') as HTMLInputElement).value;
        const genre = (document.getElementById('add-genre') as HTMLSelectElement).value;
        const year = parseInt((document.getElementById('add-year') as HTMLInputElement).value);
        const duration = parseInt((document.getElementById('add-duration') as HTMLInputElement).value);
        const atp = (document.getElementById('add-atp') as HTMLInputElement).checked;
        const platforms = (document.getElementById('add-platforms') as HTMLInputElement).value;

        try {
            // Verificar título repetido (dar_alta_titulo logic)
            const isDup = peliculas.some(m => m.titulo.toLowerCase() === title.toLowerCase());
            if (isDup) {
                throw {
                    type: 'ValueError',
                    message: 'La película que quiere ingresar ya ha sido validada. Ingrese un título nuevo.'
                };
            }

            // Generar nuevo ID único (validar_id logic)
            let maxId = 0;
            peliculas.forEach(m => {
                if (m.id > maxId) maxId = m.id;
            });
            const nextId = maxId === 0 ? 1 : maxId + 1;

            // Instanciar (aplica validaciones internas de Pelicula)
            const newMovie = new Pelicula(nextId, title, genre, year, duration, atp, platforms);
            peliculas.push(newMovie);

            // Toast de éxito
            showSuccessToast(`🎬 ¡Película "${newMovie.titulo}" dada de alta exitosamente!`);
            
            // Redirigir
            renderMoviesTable();
            activateTab('list');

        } catch (err: any) {
            showError(err.type || 'ValueError', err.message || 'Error en validación.');
        }
    });

    // --- B. Modificar ---
    const btnEditLoad = document.getElementById('btn-edit-load');
    const editSearchInput = document.getElementById('edit-search-title') as HTMLInputElement;
    const editFieldsGroup = document.getElementById('edit-fields-group');
    let editingMovie: Pelicula | null = null;

    btnEditLoad?.addEventListener('click', () => {
        hideError();
        const searchTitle = editSearchInput.value.trim().toLowerCase();
        if (!searchTitle) {
            showError('ValueError', 'Ingrese un título de búsqueda.');
            return;
        }

        // Buscar película de forma case-insensitive
        const matched = peliculas.find(m => m.titulo.toLowerCase() === searchTitle);
        if (!matched) {
            showError('ValueError', 'Error. No existe esa película con ese título.');
            editFieldsGroup.classList.add('hidden');
            editingMovie = null;
            return;
        }

        // Cargar campos
        editingMovie = matched;
        (document.getElementById('edit-title') as HTMLInputElement).value = matched.titulo;
        (document.getElementById('edit-genre') as HTMLSelectElement).value = matched.genero;
        (document.getElementById('edit-year') as HTMLInputElement).value = matched.año_lanzamiento.toString();
        (document.getElementById('edit-duration') as HTMLInputElement).value = matched.duracion.toString();
        (document.getElementById('edit-atp') as HTMLInputElement).checked = matched.atp;
        (document.getElementById('edit-platforms') as HTMLInputElement).value = matched.plataforma;

        editFieldsGroup.classList.remove('hidden');
    });

    actionForms.edit.addEventListener('submit', (e) => {
        e.preventDefault();
        hideError();
        if (!editingMovie) return;

        const newTitle = (document.getElementById('edit-title') as HTMLInputElement).value;
        const newGenre = (document.getElementById('edit-genre') as HTMLSelectElement).value;
        const newYear = parseInt((document.getElementById('edit-year') as HTMLInputElement).value);
        const newDuration = parseInt((document.getElementById('edit-duration') as HTMLInputElement).value);
        const newAtp = (document.getElementById('edit-atp') as HTMLInputElement).checked;
        const newPlatforms = (document.getElementById('edit-platforms') as HTMLInputElement).value;

        try {
            // Validar título duplicado con OTRA película
            const isDup = peliculas.some(m => m.id !== editingMovie.id && m.titulo.toLowerCase() === newTitle.toLowerCase());
            if (isDup) {
                throw {
                    type: 'ValueError',
                    message: 'Ya existe otra película cargada en el sistema con el nuevo título.'
                };
            }

            // Aplicar validaciones instanciando objeto temporal
            const temp = new Pelicula(editingMovie.id, newTitle, newGenre, newYear, newDuration, newAtp, newPlatforms);

            // Guardar cambios
            editingMovie.titulo = temp.titulo;
            editingMovie.genero = temp.genero;
            editingMovie.año_lanzamiento = temp.año_lanzamiento;
            editingMovie.duracion = temp.duracion;
            editingMovie.atp = temp.atp;
            editingMovie.plataforma = temp.plataforma;

            showSuccessToast('✏️ Película modificada correctamente.');
            editFieldsGroup.classList.add('hidden');
            actionForms.edit.reset();
            renderMoviesTable();
            activateTab('list');

        } catch (err: any) {
            showError(err.type || 'ValueError', err.message || 'Error en validación.');
        }
    });

    // --- C. Eliminar ---
    actionForms.delete.addEventListener('submit', (e) => {
        e.preventDefault();
        hideError();

        const searchTitle = (document.getElementById('delete-search-title') as HTMLInputElement).value.trim().toLowerCase();
        if (!searchTitle) {
            showError('ValueError', 'Ingrese un título para eliminar.');
            return;
        }

        const idx = peliculas.findIndex(m => m.titulo.toLowerCase() === searchTitle);
        if (idx === -1) {
            showError('ValueError', 'No existe una película con ese título.');
            return;
        }

        const deleted = peliculas.splice(idx, 1)[0];
        showSuccessToast(`❌ Película "${deleted.titulo}" eliminada.`);
        actionForms.delete.reset();
        renderMoviesTable();
        activateTab('list');
    });

    // ==========================================
    // Pestaña Consultas / Filtrado
    // ==========================================
    const querySubTabs = {
        title: document.getElementById('query-tab-title'),
        genre: document.getElementById('query-tab-genre'),
        platform: document.getElementById('query-tab-platform'),
        atp: document.getElementById('query-tab-atp')
    };

    const querySubSections = {
        title: document.getElementById('filter-code-title'),
        genre: document.getElementById('filter-code-genre'),
        platform: document.getElementById('filter-code-platform'),
        atp: document.getElementById('filter-code-atp')
    };

    const filterResultsBox = document.getElementById('query-results-box');

    function activateQuerySub(activeName) {
        Object.keys(querySubTabs).forEach(name => {
            const btn = querySubTabs[name];
            const section = querySubSections[name];
            if (name === activeName) {
                btn.className = "p-2.5 border border-theme-primary/30 rounded-xl bg-theme-primary/5 text-white font-bold cursor-pointer text-center";
                section.classList.remove('hidden');
                section.classList.add('block');
            } else {
                btn.className = "p-2.5 border border-slate-800 rounded-xl bg-slate-900/20 text-slate-400 hover:border-slate-800 transition cursor-pointer text-center";
                section.classList.remove('block');
                section.classList.add('hidden');
            }
        });
        if (filterResultsBox) filterResultsBox.innerHTML = '<p class="text-xs italic text-slate-600">Realiza una búsqueda para ver los resultados.</p>';
    }

    querySubTabs.title.addEventListener('click', () => activateQuerySub('title'));
    querySubTabs.genre.addEventListener('click', () => {
        activateQuerySub('genre');
        runQueryGenre();
    });
    querySubTabs.platform.addEventListener('click', () => activateQuerySub('platform'));
    querySubTabs.atp.addEventListener('click', () => {
        activateQuerySub('atp');
        runQueryAtp(true);
    });

    function displayFilteredList(list) {
        if (!filterResultsBox) return;
        if (list.length === 0) {
            filterResultsBox.innerHTML = '<p class="text-xs text-slate-500 italic">No se encontraron películas que coincidan con la búsqueda.</p>';
            return;
        }

        filterResultsBox.innerHTML = list.map(m => `
            <div class="p-3 border border-slate-900 bg-black/30 rounded-xl font-mono text-[10.5px] flex justify-between items-center hover:border-theme-primary/10 transition-colors">
                <div>
                    <span class="text-white font-bold">🎬 ${m.titulo}</span>
                    <p class="text-[9.5px] text-slate-500 mt-0.5">ID: ${m.id} | Género: ${m.genero} | Año: ${m.año_lanzamiento} | Duración: ${m.duracion} min</p>
                </div>
                <div class="text-right">
                    <span class="px-2 py-0.5 rounded text-[8px] font-bold uppercase bg-slate-900 border border-slate-800 text-theme-primary">${m.plataforma.split('-')[0]}</span>
                </div>
            </div>
        `).join('');
    }

    // --- A. Búsqueda por Título ---
    const queryTitleInput = document.getElementById('query-title-input') as HTMLInputElement;
    const btnFilterTitle = document.getElementById('btn-filter-title');

    function runQueryTitle() {
        const text = queryTitleInput.value.trim().toLowerCase();
        if (!text) {
            displayFilteredList(peliculas);
            return;
        }
        const filtered = peliculas.filter(m => m.titulo.toLowerCase().includes(text));
        displayFilteredList(filtered);
    }
    btnFilterTitle?.addEventListener('click', runQueryTitle);
    queryTitleInput?.addEventListener('input', runQueryTitle);

    // --- B. Búsqueda por Género ---
    const queryGenreInput = document.getElementById('query-genre-input') as HTMLSelectElement;
    const btnFilterGenre = document.getElementById('btn-filter-genre');

    function runQueryGenre() {
        const val = queryGenreInput.value;
        if (!val) {
            displayFilteredList([]);
            return;
        }
        const filtered = peliculas.filter(m => m.genero.toLowerCase() === val.toLowerCase());
        displayFilteredList(filtered);
    }
    btnFilterGenre?.addEventListener('click', runQueryGenre);
    queryGenreInput?.addEventListener('change', runQueryGenre);

    // --- C. Búsqueda por Plataforma ---
    const queryPlatformInput = document.getElementById('query-platform-input') as HTMLInputElement;
    const btnFilterPlatform = document.getElementById('btn-filter-platform');

    function runQueryPlatform() {
        const text = queryPlatformInput.value.trim().toLowerCase();
        if (!text) {
            displayFilteredList([]);
            return;
        }
        const filtered = peliculas.filter(m => m.plataforma.toLowerCase().includes(text));
        displayFilteredList(filtered);
    }
    btnFilterPlatform?.addEventListener('click', runQueryPlatform);
    queryPlatformInput?.addEventListener('input', runQueryPlatform);

    // --- D. Búsqueda por ATP ---
    const btnFilterAtpTrue = document.getElementById('btn-filter-atp-true');
    const btnFilterAtpFalse = document.getElementById('btn-filter-atp-false');

    function runQueryAtp(val) {
        btnFilterAtpTrue.className = val
            ? "flex-1 bg-theme-primary/10 border border-theme-primary/30 text-theme-primary font-bold py-3 rounded-xl transition cursor-pointer"
            : "flex-1 bg-slate-900 border border-slate-800 text-slate-400 py-3 rounded-xl hover:bg-slate-800 transition cursor-pointer";
        btnFilterAtpFalse.className = !val
            ? "flex-1 bg-theme-primary/10 border border-theme-primary/30 text-theme-primary font-bold py-3 rounded-xl transition cursor-pointer"
            : "flex-1 bg-slate-900 border border-slate-800 text-slate-400 py-3 rounded-xl hover:bg-slate-800 transition cursor-pointer";

        const filtered = peliculas.filter(m => m.atp === val);
        displayFilteredList(filtered);
    }
    btnFilterAtpTrue?.addEventListener('click', () => runQueryAtp(true));
    btnFilterAtpFalse?.addEventListener('click', () => runQueryAtp(false));

    // ==========================================
    // Pestaña Estadísticas e Informes
    // ==========================================
    const labelAvgDuration = document.getElementById('stat-avg-duration');
    const labelAvgYear = document.getElementById('stat-avg-year');
    const selectGenreStat = document.getElementById('stat-select-genre') as HTMLSelectElement;
    const labelGenrePercent = document.getElementById('stat-genre-percent');
    
    const barAtpTrue = document.getElementById('bar-atp-true');
    const barAtpFalse = document.getElementById('bar-atp-false');
    const statAtpTrueLbl = document.getElementById('stat-atp-true-lbl');
    const statAtpFalseLbl = document.getElementById('stat-atp-false-lbl');

    function calculateStatistics() {
        if (peliculas.length === 0) {
            labelAvgDuration.textContent = '0 min';
            labelAvgYear.textContent = '0';
            labelGenrePercent.textContent = '0.00%';
            barAtpTrue.style.width = '50%';
            barAtpFalse.style.width = '50%';
            statAtpTrueLbl.textContent = '0.00%';
            statAtpFalseLbl.textContent = '0.00%';
            return;
        }

        // 1. Promedio duración
        let totalDur = 0;
        let totalYear = 0;
        let totalAtp = 0;

        peliculas.forEach(m => {
            totalDur += m.duracion;
            totalYear += m.año_lanzamiento;
            if (m.atp) totalAtp++;
        });

        const avgDur = totalDur / peliculas.length;
        const avgYear = totalYear / peliculas.length;
        const pctAtp = (totalAtp / peliculas.length) * 100;
        const pctNoAtp = 100 - pctAtp;

        labelAvgDuration.textContent = `${avgDur.toFixed(2)} min`;
        labelAvgYear.textContent = `${avgYear.toFixed(1)}`;

        // 2. Proporción ATP
        barAtpTrue.style.width = `${pctAtp}%`;
        barAtpTrue.textContent = pctAtp > 10 ? `ATP` : '';
        barAtpFalse.style.width = `${pctNoAtp}%`;
        barAtpFalse.textContent = pctNoAtp > 10 ? `MAYORES` : '';

        statAtpTrueLbl.textContent = `${pctAtp.toFixed(2)}%`;
        statAtpFalseLbl.textContent = `${pctNoAtp.toFixed(2)}%`;

        // 3. Porcentaje del género seleccionado
        updateGenrePercent();
    }

    function updateGenrePercent() {
        if (peliculas.length === 0) {
            labelGenrePercent.textContent = '0.00%';
            return;
        }
        const val = selectGenreStat.value;
        const count = peliculas.filter(m => m.genero === val).length;
        const pct = (count / peliculas.length) * 100;
        labelGenrePercent.textContent = `${pct.toFixed(2)}%`;
    }

    selectGenreStat?.addEventListener('change', updateGenrePercent);

    // --- Reporte JSON ---
    const btnGenerateJson = document.getElementById('btn-generate-json');
    const jsonOutputBox = document.getElementById('json-output-box');

    btnGenerateJson?.addEventListener('click', () => {
        if (!jsonOutputBox) return;

        // Generar diccionario agrupado (como funciones_mostrar.py)
        const dict: Record<string, string[]> = {};
        peliculas.forEach(m => {
            if (!dict[m.genero]) {
                dict[m.genero] = [];
            }
            dict[m.genero].push(m.titulo);
        });

        jsonOutputBox.textContent = JSON.stringify(dict, null, 4);
        jsonOutputBox.classList.remove('hidden');
        jsonOutputBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    // ==========================================
    // Consola de Python (Simulador lateral)
    // ==========================================
    const btnRunTerminal = document.getElementById('btn-run-terminal');
    const terminalContent = document.getElementById('terminal-content');

    const terminalLogs = [
        "Analyzing project directory...",
        "Python 3.13 env checked. [SUCCESS]",
        "python main.py",
        "Loading CSV database: F:\\UTN FACULTAD\\cursada_python_cuatrimestreuno\\PARCIAL_PROYECTO\\peliculass.csv",
        "Deduplicating movies by title... [OK]",
        "Loaded 95 active movies.",
        "",
        "**** WELCOME TO NANI'S CINEMA ****",
        "Elija una de las siguiente opciones: ",
        "1. DAR ALTA",
        "2. MODIFICAR",
        "3. ELIMINAR",
        "4. MOSTRAR PELICULAS",
        "5. ORDENAR PELICULAS",
        "6. BUSCAR PELICULA POR TITULO",
        "7. CALCULAR PROMEDIO",
        "8. CALCULAR PORCENTAJE",
        "9. SALIR",
        "",
        "Selecting option: 4 (MOSTRAR)",
        "*************************************************************************************************",
        "| Titulo                                             | Genero                    | Año de lanzamiento | Duración | ATP | Plataforma                     |",
        "-------------------------------------------------------------------------------------------------",
        "| Titanic                                            | Romance                   | 1997               | 195      | No  | Disney+-Amazon Prime           |",
        "| Los 8 más odiados                                  | Western                   | 2015               | 187      | No  | Netflix                        |",
        "| Vengadores: endgame                                | Superhéroes               | 2019               | 181      | Si  | Disney+                        |",
        "| El lobo de wall street                             | Biográfico                | 2013               | 180      | No  | Netflix-Amazon Prime           |",
        "| El señor de los anillos: las dos torres            | Fantasía                  | 2002               | 179      | No  | Amazon Prime                   |",
        "| Corazón valiente                                   | Histórico                 | 1995               | 178      | No  | Netflix-Amazon Prime           |",
        "| El señor de los anillos: la comunidad del anillo   | Fantasía                  | 2001               | 178      | Si  | Amazon Prime                   |",
        "| El padrino                                         | Crimen                    | 1972               | 175      | No  | HBO Max-Amazon Prime           |",
        "| Interestelar                                       | Ciencia ficción           | 2014               | 169      | No  | Netflix-Amazon Prime           |",
        "| Toy story                                          | Animación                 | 1995               | 81       | Si  | Disney+                        |",
        "*************************************************************************************************",
        "",
        "Selecting option: 7 (PROMEDIO -> DURACIÓN)",
        "El promedio de duracion es 169.60 min [OK]",
        "",
        "Selecting option: 8 (PORCENTAJE -> ATP)",
        "el porcentaje de ATP positivo es: 30.00% y el porcentaje de ATP negativo es: 70.00% [OK]",
        "",
        "Selecting option: 9 (SALIR)",
        "Saving state to peliculass.csv... success",
        "Process exited with exit code 0.",
        "",
        "¡PROYECTO PYTHON VERIFICADO Y OPERATIVO EN SU TOTALIDAD! 🎉"
    ];

    btnRunTerminal?.addEventListener('click', () => {
        if (!terminalContent) return;
        
        btnRunTerminal.disabled = true;
        btnRunTerminal.classList.add('opacity-50', 'pointer-events-none');
        
        terminalContent.innerHTML = '<span class="text-theme-primary">Ignacio-MacBook-Pro:~$</span> python main.py<br/>';
        
        let index = 0;
        
        function printLine() {
            if (index < terminalLogs.length) {
                const line = terminalLogs[index];
                const p = document.createElement('div');
                
                if (line.includes('[SUCCESS]') || line.includes('[OK]') || line.includes('ÉXITO') || line.includes('0.')) {
                    p.className = 'text-emerald-400 font-bold';
                } else if (line.includes('Error') || line.includes('Exception')) {
                    p.className = 'text-rose-400';
                } else if (line.startsWith('Selecting') || line.startsWith('****') || line.startsWith('1.') || line.startsWith('9.')) {
                    p.className = 'text-white font-bold';
                } else if (line.startsWith('|')) {
                    p.className = 'text-emerald-300 font-mono text-[9.5px] whitespace-pre';
                } else {
                    p.className = 'text-slate-400';
                }
                
                p.textContent = line;
                terminalContent.appendChild(p);
                terminalContent.scrollTop = terminalContent.scrollHeight;
                index++;
                setTimeout(printLine, 100);
            } else {
                const endDiv = document.createElement('div');
                endDiv.className = 'mt-3 text-slate-500';
                endDiv.innerHTML = '<span class="text-theme-primary">Ignacio-MacBook-Pro:~$</span> <span class="animate-pulse">_</span>';
                terminalContent.appendChild(endDiv);
                
                btnRunTerminal.disabled = false;
                btnRunTerminal.classList.remove('opacity-50', 'pointer-events-none');
            }
        }
        
        setTimeout(printLine, 400);
    });

    // Toast de éxito UI helper
    function showSuccessToast(message) {
        const toast = document.createElement('div');
        toast.className = "fixed bottom-5 right-5 bg-emerald-950 border border-emerald-500/30 text-emerald-400 p-4 rounded-xl shadow-2xl z-50 text-xs font-mono animate-bounce";
        toast.innerHTML = `✅ ${message}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    // Inicializar render
    renderMoviesTable();

    // ==========================================
    // Sistema de Traducción Local (Dual-Lang)
    // ==========================================
    const demoTranslations = {
        es: {
            back_btn: "← Volver al inicio",
