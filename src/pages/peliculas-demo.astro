            lbl_atp: "¿Es Apta Todo Público?",
            lbl_platforms: "Plataformas de Distribución (Separadas por guión \"-\")",
            platforms_note: "⚠️ Nota: Las plataformas no deben contener números (validado por validaciones.py).",
            btn_submit_add: "Registrar Nueva Película",
