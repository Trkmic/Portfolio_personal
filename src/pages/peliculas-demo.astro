            edit_search_lbl: "Paso 1: Ingrese el Título de la película a modificar",
            delete_search_lbl: "Ingrese el Título de la película a eliminar",
            query_results: "Resultados de la Consulta",
            query_no_searched: "No se ha realizado ninguna búsqueda aún."
        },
        en: {
            back_btn: "← Back to home",
            page_title: "Movie Management Simulator (Python)",
            page_subtitle: "Interactive Python Data Processing Logic Ported to the Web",
            python_structure: "Python Project Architecture",
            tab_movies: "Movies List",
            tab_manage: "Manage",
            tab_query: "Queries",
            tab_stats: "Statistics",
            list_title: "Movies in Database (CSV)",
            lbl_title: "Movie Title",
            lbl_genre: "Genre",
            lbl_year: "Release Year",
            lbl_duration: "Duration (Minutes)",
            lbl_atp: "Is General Audience (ATP)?",
            lbl_platforms: "Distribution Platforms (Separated by dash \"-\")",
            platforms_note: "⚠️ Note: Platforms must not contain numbers (validated by validaciones.py).",
            btn_submit_add: "Register New Movie",
            btn_submit_edit: "Save Changes",
            edit_search_lbl: "Step 1: Enter Title of the movie to modify",
            delete_search_lbl: "Enter Title of the movie to delete",
            query_results: "Query Results",
            query_no_searched: "No query has been executed yet."
        }
    };

    function translateDemoPage(lang) {
        const dict = demoTranslations[lang] || demoTranslations.es;
        const elements = document.querySelectorAll('[data-demo-i18n]');
        elements.forEach(el => {
            const key = el.getAttribute('data-demo-i18n');
            if (key && dict[key]) {
                el.innerHTML = dict[key];
            }
        });
    }

    // Idioma activo inicial
    let activeLang = (localStorage.getItem('language') || 'es') as 'es' | 'en';
    translateDemoPage(activeLang);

    // Escuchar cambios globales de idioma
    window.addEventListener('language-changed', (e: any) => {
        activeLang = e.detail.language;
        translateDemoPage(activeLang);
        calculateStatistics(); // recalcular textos locales
    });
</script>

