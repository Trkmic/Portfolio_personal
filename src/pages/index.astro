---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AIChatbot from '../components/AIChatbot.astro';
import AIJobMatcher from '../components/AIJobMatcher.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import ThemeModeToggle from '../components/ThemeModeToggle.astro';
import NavigationSearch from '../components/NavigationSearch.astro';
import TerminalConsole from '../components/TerminalConsole.astro';

const nombreCompleto = "Ignacio Trkmic Torres";
const edad = 20;
const estudios = "Estudiante de la Tecnicatura Universitaria en Programación (a 2 materias del título) e Ingeniería Mecánica";
const ingles = "Nivel B2 de inglés (First Certificate aprobado)";

const stackTecnologico = [
    { nombre: "Python", icono: "devicon-python-plain" },
    { nombre: "Java", icono: "devicon-java-plain" },
    { nombre: "JavaScript", icono: "devicon-javascript-plain" },
    { nombre: "TypeScript", icono: "devicon-typescript-plain" },
    { nombre: "HTML", icono: "devicon-html5-plain" },
    { nombre: "CSS", icono: "devicon-css3-plain" },
    { nombre: "Angular", icono: "devicon-angular-plain" },
    { nombre: "SQL", icono: "devicon-azuresqldatabase-plain" },
    { nombre: "MongoDB", icono: "devicon-mongodb-plain" },
    { nombre: "Astro", icono: "devicon-astro-plain" },
    { fontName: "VSCode", icono: "devicon-vscode-plain", nombre: "VSCode" },
    { nombre: "NestJs", icono: "devicon-nestjs-original" },
    { nombre: "Supabase", icono: "devicon-supabase-plain" },
    { nombre: "Vercel", icono: "devicon-vercel-original" },
];

const doubleStack = [...stackTecnologico, ...stackTecnologico];

const proyectos = [
	{
		slug: "red-social",
		titulo: "Red social",
		descripcion: "Plataforma social con NestJS y Angular. Incluye autenticación JWT, dashboards de estadísticas con Chart.js y gestión de medios en Cloudinary.",
		tags: ["Angular", "Bootstrap", "NestJS", "MongoDB", "TypeScript", "CSS", "HTML"],
		linkGithub: "https://github.com/Trkmic/red-social",
        linkWeb: "https://red-social-sage.vercel.app/",
	},
	{
		slug: "sala-de-juegos",
		titulo: "Sala de juegos",
		descripcion: "Suite de juegos con sistema de usuarios y chat en tiempo real. Utiliza Supabase para la base de datos y Vercel para el despliegue.",
		tags: ["TypeScript", "CSS", "HTML", "Angular","Supabase", "Express"],
		linkGithub: "https://github.com/Trkmic/sala-de-juegos",
        linkWeb: "https://sala-de-juegos-tau.vercel.app/home",
	},
	{
		slug: "tienda_online",
		titulo: "Tienda Online",
		descripcion: "E-commerce con panel de administración. Gestión de inventario, carrito de compras y registro de ventas vinculado a una base de datos SQL.",
		tags: ["JavaScript", "CSS", "HTML", "SQL"],
		linkGithub: "https://github.com/Trkmic/tienda_online",
        linkWeb: "#",
	},
	{
		slug: "servicio_hospedaje_gatronomia",
		titulo: "Servicio de hospedaje y gastronomia",
		descripcion: "Sistema en Java enfocado en POO para la administración de servicios turísticos, cálculos dinámicos de costos y gestión de inventario.",
		tags: ["Java", "POO"],
		linkGithub: "https://github.com/Trkmic/servicio_hospedaje_gatronomia",
        linkWeb: "#",
	},
	{
		slug: "pygame_adivina_pokemon",
		titulo: "Adivina el pokemon",
		descripcion: "Juego de trivia con Pygame. Soporte multi-idioma, manejo de archivos JSON/CSV para puntajes y base de datos, y lógica de estados.",
		tags: ["Python", "Pygame"],
		linkGithub: "https://github.com/Trkmic/pygame_adivina_pokemon",
        linkWeb: "#",
	},
	{
		slug: "Gestion_peliculas",
		titulo: "Gestion de peliculas",
		descripcion: "Sistema de procesamiento de datos con Python. Manejo de catálogos en CSV/JSON, algoritmos de ordenamiento y generación de reportes estadísticos.",
		tags: ["Python"],
		linkGithub: "https://github.com/Trkmic/Gestion_peliculas",
        linkWeb: "#",
	}
];
---

<Layout>
    <!-- Selector de Temas y Barra de Mandos -->
    <ThemeSwitcher />
    <!-- Toggle de Modo Claro/Oscuro -->
    <ThemeModeToggle />
    <!-- Buscador Navegador Superior -->
    <NavigationSearch />

    <!-- Efecto de Fondo Neon/Malla dinámico -->
    <div class="fixed inset-0 z-0 bg-black overflow-hidden pointer-events-none">
        <div class="absolute top-[10%] left-[20%] w-[400px] h-[400px] rounded-full bg-theme-primary/5 blur-[120px] transition-all duration-700"></div>
        <div class="absolute bottom-[20%] right-[10%] w-[500px] h-[500px] rounded-full bg-theme-secondary/5 blur-[150px] transition-all duration-700"></div>
    </div>

    <main class="relative z-10 max-w-2xl mx-auto px-6 pt-32 pb-12 flex flex-col gap-12 min-h-screen text-slate-300 font-sans">
        
        <!-- Header / Perfil -->
        <section class="flex flex-col items-center sm:items-start sm:flex-row gap-6">
            <div class="relative group">
                <div class="absolute -inset-1 rounded-full bg-gradient-to-r from-theme-primary to-theme-bg opacity-75 blur-md group-hover:opacity-100 transition-opacity duration-500"></div>
                <img 
                    src="foto_nueva.jpeg" 
                    alt="Avatar de Ignacio Torres" 
                    class="relative w-32 h-32 rounded-full border-4 border-theme-primary/80 shadow-[0_0_20px_var(--theme-glow)] object-cover transition-all duration-500"
                />
            </div>
            <div class="flex flex-col text-center sm:text-left justify-center">
                <h1 class="text-4xl font-bold text-white mb-1 tracking-tight">{nombreCompleto}</h1>
                
                <p class="text-theme-primary font-mono text-lg font-semibold uppercase tracking-wider flex items-center justify-center sm:justify-start gap-2">
                    <span class="inline-block w-2.5 h-2.5 rounded-full bg-theme-primary animate-pulse"></span>
                    <span data-i18n="profile_location">Buenos Aires, Argentina</span>
                </p>
                <div class="flex flex-wrap justify-center sm:justify-start gap-2 mt-2.5 font-mono">
                    <span class="bg-theme-primary/10 text-theme-primary border border-theme-primary/30 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide" data-i18n="profile_title_fullstack">
                        Desarrollador Full-Stack
                    </span>
                    <span class="bg-theme-secondary/10 text-theme-secondary border border-theme-secondary/30 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide" data-i18n="profile_title_backend">
                        Backend & Integración de IA
                    </span>
                </div>
                
                <div class="flex justify-center sm:justify-start gap-5 text-2xl mt-3">
                    <a href="https://linkedin.com/in/ignacio-trkmic-5a797827a/" 
                       target="_blank" 
                       rel="noopener noreferrer"
                       class="text-slate-600 hover:text-theme-primary hover:scale-125 transition-all duration-300"
                       title="LinkedIn"
                       data-i18n-title="profile_linkedin_title">
                        <i class="fa-brands fa-linkedin"></i>
                    </a>
                    <a href="https://github.com/Trkmic" 
                       target="_blank" 
                       rel="noopener noreferrer"
                       class="text-white hover:text-theme-primary hover:scale-125 transition-all duration-300"
                       title="GitHub"
                       data-i18n-title="profile_github_title">
                        <i class="fa-brands fa-github"></i>
                    </a>
                    <a href="https://mail.google.com/mail/?view=cm&fs=1&to=trkmicignacio@gmail.com" 
                       target="_blank"
                       rel="noopener noreferrer"
                       class="text-theme-primary hover:text-theme-primary/80 hover:scale-125 transition-all duration-300"
                       title="Enviar Email (Gmail)"
                       data-i18n-title="profile_email_title">
                        <i class="fa-solid fa-envelope"></i>
                    </a>
                </div>
            </div>
        </section>

        <!-- Sobre Mí -->
        <section id="about-section" class="bg-slate-950/40 p-6 rounded-2xl border border-theme-secondary/35 shadow-[inset_0_0_15px_var(--theme-glow)] hover:border-theme-primary/30 transition-all duration-300">
            <h2 class="text-xl font-bold mb-4 text-theme-primary font-mono tracking-wide uppercase" data-i18n="about_title">Sobre Mí</h2>
            <div class="space-y-4 text-slate-300">
                <div class="flex gap-4 items-start">
                    <i class="fa-solid fa-graduation-cap mt-1 text-theme-primary text-lg"></i>
                    <p data-i18n="about_studies">{estudios}.</p>
                </div>
                <div class="flex gap-4 items-start">
                    <i class="fa-solid fa-language mt-1 text-theme-primary text-lg"></i>
                    <p data-i18n="about_english">{ingles}.</p>
                </div>
                <div class="flex gap-4 items-start">
                    <i class="fa-solid fa-code mt-1 text-theme-primary text-lg"></i>
                    <p data-i18n="about_passion">Apasionado por resolver problemas complejos y construir soluciones backend sólidas y frontend altamente interactivas.</p>
                </div>
                <a 
                    href="/CV_Trkmic (2) copy.pdf" 
                    download="CV_Ignacio_Trkmic.pdf"
                    class="mt-4 w-full bg-theme-primary hover:scale-[1.02] text-black font-black py-3 rounded-xl transition-all shadow-[0_0_15px_var(--theme-glow)] hover:shadow-[0_0_25px_var(--theme-glow)] uppercase tracking-tight flex justify-center items-center text-center decoration-none cursor-pointer"
                >
                    <i class="fa-solid fa-download mr-2"></i> <span data-i18n="about_download_cv">Descargar CV</span>
                </a>
            </div>
        </section>

        <!-- Stack Tecnológico -->
        <section class="space-y-4">
            <h2 class="text-sm font-bold text-center text-theme-primary uppercase tracking-[0.3em] font-mono" data-i18n="stack_title">Stack Tecnológico</h2>
            <p class="text-[11px] text-center text-slate-500 font-mono italic" data-i18n="stack_subtitle">Haz clic en una tecnología para filtrar los proyectos</p>
            
            <div class="relative flex overflow-hidden group border-y border-theme-secondary/20 py-2">
                <!-- Capas de sombra laterales para el carrusel -->
                <div class="absolute left-0 top-0 bottom-0 w-12 bg-gradient-to-r from-black to-transparent z-20 pointer-events-none"></div>
                <div class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-black to-transparent z-20 pointer-events-none"></div>
                
                <div class="flex gap-8 animate-marquee whitespace-nowrap py-4">
                    {doubleStack.map((tech) => (
                        <button 
                            class="tech-filter-btn flex flex-col items-center gap-2 group/btn hover:scale-115 transition-all duration-300 cursor-pointer bg-transparent border-none outline-none"
                            data-tech={tech.nombre.toLowerCase()}
                        >
                            <i class={`${tech.icono} text-4xl text-theme-primary/80 group-hover/btn:text-theme-primary transition-colors duration-300`}></i> 
                            <span class="text-[10px] text-slate-600 group-hover/btn:text-theme-primary uppercase font-bold font-mono tracking-tight">{tech.nombre}</span>
                        </button>
                    ))}
                </div>
            </div>
        </section>

        <!-- Proyectos Realizados -->
        <section id="projects-section" class="flex flex-col gap-6">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-theme-secondary/50 pb-2 gap-2">
                <h2 class="text-xl font-bold text-theme-primary font-mono uppercase tracking-wider" data-i18n="projects_title">Proyectos Realizados</h2>
                
                <!-- Estado del filtro activo -->
                <div id="filter-status" class="hidden items-center gap-2.5 text-xs font-mono text-theme-primary bg-theme-bg/20 px-3 py-1.5 rounded-lg border border-theme-secondary/30">
                    <span><span data-i18n="projects_filtering">Filtrando:</span> <strong id="current-filter-name" class="uppercase text-white"></strong></span>
                    <button id="clear-filter-btn" class="text-rose-400 hover:text-rose-300 font-bold ml-1 cursor-pointer transition-colors" title="Quitar filtro" data-i18n-title="projects_clear_filter">
                        <i class="fa-solid fa-circle-xmark"></i>
                    </button>
                </div>
            </div>
            
            <div class="grid sm:grid-cols-1 gap-6" id="projects-grid">
                {proyectos.map((proy) => (
                    <ProjectCard 
                        slug={proy.slug}
                        titulo={proy.titulo}
                        descripcion={proy.descripcion}
                        tags={proy.tags}
                        linkGithub={proy.linkGithub}
                        linkWeb={proy.linkWeb}
                    />
                ))}
            </div>
        </section>

        <!-- Formación Académica (Línea de Tiempo Neon) -->
        <section id="academic-section" class="flex flex-col gap-6 relative">
            <h2 class="text-xl font-bold text-theme-primary border-b border-theme-secondary/50 pb-2 font-mono uppercase tracking-wider" data-i18n="academic_title">
                Formación Académica
            </h2>
            
            <div class="relative pl-8 border-l-2 border-slate-900 ml-4 space-y-8 py-2" id="academic-timeline">
                <!-- Barra de progreso neon interactiva por scroll -->
                <div 
                  id="timeline-progress-bar" 
                  class="absolute top-0 left-[-2px] w-[2px] bg-theme-primary shadow-[0_0_12px_var(--theme-glow)] transition-all duration-500 ease-out origin-top scale-y-0 h-full"
                ></div>

                <!-- Punto 1: UTN Ing Mecánica -->
                <div class="timeline-item relative group">
                    <div class="timeline-node absolute left-[-41px] top-4 w-4.5 h-4.5 rounded-full bg-black border-2 border-slate-900 transition-all duration-500 z-10"></div>
                    
                    <div class="p-5 rounded-xl bg-black border border-theme-secondary/40 flex flex-col sm:flex-row justify-between sm:items-center gap-4 group hover:border-theme-primary/40 hover:shadow-[0_0_15px_var(--theme-glow)] transition-all duration-300">
                        <div class="flex gap-4 items-center">
                            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 transition-all duration-300">
                                <i class="fa-solid fa-gears text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-white font-bold group-hover:text-theme-primary transition-colors">UTN Avellaneda</h3>
                                <p class="text-theme-secondary text-sm italic" data-i18n="academic_timeline_mec_title">Ingeniería Mecánica</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-mono font-bold text-theme-primary bg-theme-primary/10 px-2.5 py-1 rounded-md uppercase self-start sm:self-auto shrink-0" data-i18n="academic_timeline_mec_date">2026 - ACT</span>
                    </div>
                </div>

                <!-- Punto 2: UTN Programación -->
                <div class="timeline-item relative group">
                    <div class="timeline-node absolute left-[-41px] top-4 w-4.5 h-4.5 rounded-full bg-black border-2 border-slate-900 transition-all duration-500 z-10"></div>
                    
                    <div class="p-5 rounded-xl bg-black border border-theme-secondary/40 flex flex-col sm:flex-row justify-between sm:items-center gap-4 group hover:border-theme-primary/40 hover:shadow-[0_0_15px_var(--theme-glow)] transition-all duration-300">
                        <div class="flex gap-4 items-center">
                            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 transition-all duration-300">
                                <i class="fa-solid fa-terminal text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-white font-bold group-hover:text-theme-primary transition-colors">UTN Avellaneda</h3>
                                <p class="text-theme-secondary text-sm italic" data-i18n="academic_timeline_prog_title">Tecnicatura Universitaria en Programación</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-mono font-bold text-theme-primary bg-theme-primary/10 px-2.5 py-1 rounded-md uppercase self-start sm:self-auto shrink-0" data-i18n="academic_timeline_prog_date">2024 - 2026</span>
                    </div>
                </div>

                <!-- Punto 3: English Time -->
                <div class="timeline-item relative group">
                    <div class="timeline-node absolute left-[-41px] top-4 w-4.5 h-4.5 rounded-full bg-black border-2 border-slate-900 transition-all duration-500 z-10"></div>
                    
                    <div class="p-5 rounded-xl bg-black border border-theme-secondary/40 flex flex-col sm:flex-row justify-between sm:items-center gap-4 group hover:border-theme-primary/40 hover:shadow-[0_0_15px_var(--theme-glow)] transition-all duration-300">
                        <div class="flex gap-4 items-center">
                            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 transition-all duration-300">
                                <i class="fa-solid fa-language text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-white font-bold group-hover:text-theme-primary transition-colors">English Time</h3>
                                <p class="text-theme-secondary text-sm italic" data-i18n="academic_timeline_english_title">Cultural de Inglés</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-mono font-bold text-theme-primary bg-theme-primary/10 px-2.5 py-1 rounded-md uppercase self-start sm:self-auto shrink-0" data-i18n="academic_timeline_english_date">2018 - 2024</span>
                    </div>
                </div>

                <!-- Punto 4: Padre Marquez -->
                <div class="timeline-item relative group">
                    <div class="timeline-node absolute left-[-41px] top-4 w-4.5 h-4.5 rounded-full bg-black border-2 border-slate-900 transition-all duration-500 z-10"></div>
                    
                    <div class="p-5 rounded-xl bg-black border border-theme-secondary/40 flex flex-col sm:flex-row justify-between sm:items-center gap-4 group hover:border-theme-primary/40 hover:shadow-[0_0_15px_var(--theme-glow)] transition-all duration-300">
                        <div class="flex gap-4 items-center">
                            <div class="w-10 h-10 rounded-lg bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 transition-all duration-300">
                                <i class="fa-solid fa-school text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-white font-bold group-hover:text-theme-primary transition-colors">Instituto Padre Marquez</h3>
                                <p class="text-theme-secondary text-sm italic" data-i18n="academic_timeline_marquez_title">Educación Secundaria</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-mono font-bold text-theme-primary bg-theme-primary/10 px-2.5 py-1 rounded-md uppercase self-start sm:self-auto shrink-0" data-i18n="academic_timeline_marquez_date">2018 - 2023</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Comparador Inteligente de Puestos -->
        <div id="job-matcher-section">
            <AIJobMatcher />
        </div>

        <!-- Contacto -->
        <section id="contact-section" class="flex flex-col gap-6 mb-6">
            <h2 class="text-xl font-bold text-theme-primary border-b border-theme-secondary/50 pb-2 font-mono uppercase tracking-wider" data-i18n="contact_title">
                Contacto
            </h2>
            
            <div class="bg-slate-950/40 p-6 sm:p-8 rounded-2xl border border-theme-secondary/35 space-y-6 hover:border-theme-primary/30 transition-all duration-300">
                <div class="text-center sm:text-left">
                    <h3 class="text-2xl font-bold text-white">{nombreCompleto}</h3>
                    <p class="text-theme-primary font-mono mt-1 uppercase italic tracking-wider text-xs" data-i18n="contact_subtitle">Desarrollador Backend / Fullstack</p>
                    <p class="text-slate-400 text-sm mt-3" data-i18n="contact_desc">
                        ¿Tienes una propuesta laboral, proyecto o consulta? Escríbeme directamente desde el formulario.
                    </p>
                </div>

                <!-- Formulario interactivo -->
                <form id="contact-form" class="space-y-4">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div class="space-y-1.5">
                            <label for="contact-name" class="text-[11px] font-bold text-slate-400 uppercase font-mono tracking-wider" data-i18n="contact_label_name">Nombre</label>
                            <input 
                                type="text" 
                                id="contact-name" 
                                name="name" 
                                required
                                placeholder="Tu nombre" 
                                class="w-full bg-black border border-theme-secondary/30 rounded-xl p-3 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-theme-primary/50 transition-colors"
                                data-i18n-placeholder="contact_placeholder_name"
                            />
                        </div>
                        <div class="space-y-1.5">
                            <label for="contact-email" class="text-[11px] font-bold text-slate-400 uppercase font-mono tracking-wider" data-i18n="contact_label_email">Correo Electrónico</label>
                            <input 
                                type="email" 
                                id="contact-email" 
                                name="email" 
                                required
                                placeholder="tu@correo.com" 
                                class="w-full bg-black border border-theme-secondary/30 rounded-xl p-3 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-theme-primary/50 transition-colors"
                                data-i18n-placeholder="contact_placeholder_email"
                            />
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label for="contact-subject" class="text-[11px] font-bold text-slate-400 uppercase font-mono tracking-wider" data-i18n="contact_label_subject">Asunto</label>
                        <input 
                            type="text" 
                            id="contact-subject" 
                            name="subject" 
                            required
                            placeholder="Motivo del mensaje" 
                            class="w-full bg-black border border-theme-secondary/30 rounded-xl p-3 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-theme-primary/50 transition-colors"
                            data-i18n-placeholder="contact_placeholder_subject"
                        />
                    </div>

                    <div class="space-y-1.5">
                        <label for="contact-message" class="text-[11px] font-bold text-slate-400 uppercase font-mono tracking-wider" data-i18n="contact_label_message">Mensaje</label>
                        <textarea 
                            id="contact-message" 
                            name="message" 
                            rows="4" 
                            required
                            placeholder="Escribe tu mensaje aquí..." 
                            class="w-full bg-black border border-theme-secondary/30 rounded-xl p-3 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-theme-primary/50 transition-colors resize-none"
                            data-i18n-placeholder="contact_placeholder_message"
                        ></textarea>
                    </div>

                    <!-- Estado de envío (éxito/error/instrucción) -->
                    <div id="contact-status" class="hidden text-xs p-3.5 rounded-xl border font-mono"></div>

                    <button 
                        type="submit" 
                        id="contact-submit-btn"
                        class="w-full bg-theme-primary hover:bg-theme-primary/90 text-black font-black py-3 rounded-xl transition-all shadow-[0_0_15px_var(--theme-glow)] hover:shadow-[0_0_25px_var(--theme-glow)] uppercase tracking-tight flex justify-center items-center gap-2 cursor-pointer"
                    >
                        <i class="fa-solid fa-paper-plane"></i> <span data-i18n="contact_btn">Enviar Mensaje</span>
                    </button>
                </form>

                <div class="border-t border-theme-secondary/20 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <a 
                        href="https://mail.google.com/mail/?view=cm&fs=1&to=trkmicignacio@gmail.com" 
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 text-slate-400 hover:text-theme-primary transition-colors text-sm font-mono"
                    >
                        <i class="fa-solid fa-envelope"></i>
                        trkmicignacio@gmail.com
                    </a>

                    <div class="flex gap-6 text-2xl">
                        <a href="https://linkedin.com/in/ignacio-trkmic-5a797827a/" 
                           target="_blank" 
                           rel="noopener noreferrer"
                           class="hover:scale-125 transition-transform text-slate-600 hover:text-theme-primary"
                           title="LinkedIn"
                           data-i18n-title="profile_linkedin_title">
                            <i class="fa-brands fa-linkedin"></i>
                        </a>

                        <a href="https://github.com/Trkmic" 
                           target="_blank" 
                           rel="noopener noreferrer"
                           class="hover:scale-125 transition-transform text-white hover:text-theme-primary"
                           title="GitHub"
                           data-i18n-title="profile_github_title">
                            <i class="fa-brands fa-github"></i>
                        </a>
                    </div>
                </div>
                
                <p class="text-slate-600 text-[11px] italic font-mono text-center" data-i18n="contact_footnote">
                    Abierto a pasantías, posiciones junior y proyectos freelance.
                </p>
            </div>
        </section>

        <!-- Footer -->
        <footer class="text-center py-8 text-slate-600 text-[12px] font-mono border-t border-theme-secondary/10">
            <p data-i18n="footer_text">© {new Date().getFullYear()} - Creado con Astro, Tailwind CSS v4 & Inteligencia Artificial </p>
        </footer>
    </main>

    <!-- Chatbot Flotante -->
    <AIChatbot />

    <!-- Consola Hacker Terminal Modal -->
    <TerminalConsole />
</Layout>

<script>
    import { translations } from '../utils/translations';

    // Idioma activo de la página
    let currentLang = (localStorage.getItem('language') || 'es') as 'es' | 'en';

    // Función para traducir elementos del DOM
    function translatePage(lang: 'es' | 'en') {
        const dict = translations[lang];
        if (!dict) return;

        // 1. Traducir textos (data-i18n)
        const elements = document.querySelectorAll('[data-i18n]');
        elements.forEach((el) => {
            const key = el.getAttribute('data-i18n');
            if (key && (dict as any)[key]) {
                el.innerHTML = (dict as any)[key];
            }
        });

        // 2. Traducir placeholders (data-i18n-placeholder)
        const placeholders = document.querySelectorAll('[data-i18n-placeholder]');
        placeholders.forEach((el) => {
            const key = el.getAttribute('data-i18n-placeholder');
            if (key && (dict as any)[key]) {
                (el as HTMLInputElement | HTMLTextAreaElement).placeholder = (dict as any)[key];
            }
        });

        // 3. Traducir titles/tooltips (data-i18n-title)
        const titles = document.querySelectorAll('[data-i18n-title]');
        titles.forEach((el) => {
            const key = el.getAttribute('data-i18n-title');
            if (key && (dict as any)[key]) {
                (el as HTMLElement).title = (dict as any)[key];
            }
        });

        // 4. Traducir metadatos del documento
        if (dict.meta_title) document.title = dict.meta_title;
        
        const metaDesc = document.querySelector('meta[name="description"]');
        if (metaDesc && dict.meta_description) {
            metaDesc.setAttribute('content', dict.meta_description);
        }
        const metaKeywords = document.querySelector('meta[name="keywords"]');
        if (metaKeywords && dict.meta_keywords) {
            metaKeywords.setAttribute('content', dict.meta_keywords);
        }
    }

    // Traducir al iniciar
    translatePage(currentLang);

    // Escuchar el evento global de cambio de idioma
    window.addEventListener('language-changed', (e: any) => {
        currentLang = e.detail.language;
        translatePage(currentLang);
    });

    // Lógica para filtrar proyectos al hacer clic en el stack
    const filterButtons = document.querySelectorAll('.tech-filter-btn');
    const projectCards = document.querySelectorAll('.project-card');
    const filterStatus = document.getElementById('filter-status');
    const filterNameLabel = document.getElementById('current-filter-name');
    const clearFilterBtn = document.getElementById('clear-filter-btn');

    let currentFilter: string | null = null;

    function applyFilter(tech: string) {
        currentFilter = tech;
        
        // Mostrar estado del filtro
        if (filterStatus && filterNameLabel) {
            filterStatus.classList.remove('hidden');
            filterStatus.classList.add('flex');
            filterNameLabel.textContent = tech;
        }

        // Resaltar u ocultar tarjetas de proyectos
        projectCards.forEach(card => {
            const cardTags = card.getAttribute('data-tags')?.split(',') || [];
            
            // Especiales (ej. NestJs vs nestjs)
            const isMatch = cardTags.some(tag => {
                const cleanTag = tag.trim().toLowerCase();
                return cleanTag === tech || 
                       (tech === 'nestjs' && cleanTag === 'nest') || 
                       (tech === 'sql' && (cleanTag === 'mysql' || cleanTag === 'postgres' || cleanTag === 'sqlite'));
            });

            if (isMatch) {
                card.classList.remove('opacity-30', 'scale-95', 'pointer-events-none', 'border-theme-secondary/10');
                card.classList.add('opacity-100', 'scale-100', 'border-theme-primary/40', 'shadow-[0_0_15px_var(--theme-glow)]');
            } else {
                card.classList.remove('opacity-100', 'scale-100', 'border-theme-primary/40', 'shadow-[0_0_15px_var(--theme-glow)]');
                card.classList.add('opacity-30', 'scale-95', 'pointer-events-none', 'border-theme-secondary/10');
            }
        });
    }

    function clearFilter() {
        currentFilter = null;

        // Ocultar estado del filtro
        if (filterStatus) {
            filterStatus.classList.remove('flex');
            filterStatus.classList.add('hidden');
        }

        // Restablecer todas las tarjetas a su estado normal
        projectCards.forEach(card => {
            card.classList.remove('opacity-30', 'scale-95', 'pointer-events-none', 'border-theme-secondary/10', 'border-theme-primary/40', 'shadow-[0_0_15px_var(--theme-glow)]');
            card.classList.add('opacity-100', 'scale-100', 'border-slate-900');
        });
    }

    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const tech = btn.getAttribute('data-tech');
            if (tech) {
                if (currentFilter === tech) {
                    clearFilter();
                } else {
                    applyFilter(tech);
                }
            }
        });
    });

    clearFilterBtn?.addEventListener('click', clearFilter);

    // ==========================================
    // API de GitHub en Vivo para Proyectos
    // ==========================================
    async function fetchGitHubStats() {
        const containers = document.querySelectorAll('.github-stats-container');
        
        for (const container of containers) {
            const repoName = container.getAttribute('data-repo');
            if (!repoName) continue;

            try {
                const response = await fetch(`https://api.github.com/repos/Trkmic/${repoName}`);
                if (!response.ok) continue;

                const data = await response.json();

                const starsCountEl = container.querySelector('.stars-count');
                const forksCountEl = container.querySelector('.forks-count');
                const commitDateEl = container.querySelector('.commit-date');

                if (starsCountEl) starsCountEl.textContent = data.stargazers_count;
                if (forksCountEl) forksCountEl.textContent = data.forks_count;
                
                if (commitDateEl && data.pushed_at) {
                    const date = new Date(data.pushed_at);
                    const formattedDate = `${date.getDate().toString().padStart(2, '0')}/${(date.getMonth() + 1).toString().padStart(2, '0')}`;
                    commitDateEl.textContent = formattedDate;
                }

                container.classList.remove('hidden');
                container.classList.add('flex');
            } catch (err) {
                console.warn(`No se pudieron obtener métricas para el repositorio ${repoName}:`, err);
            }
        }
    }

    fetchGitHubStats();

    // ==========================================
    // Línea de Tiempo Académica Neon Interactiva
    // ==========================================
    const timelineItems = document.querySelectorAll('.timeline-item');
    const progressBar = document.getElementById('timeline-progress-bar');

    const observerOptions = {
        root: null,
        rootMargin: '0px 0px -15% 0px',
        threshold: 0.25
    };

    const timelineObserver = new IntersectionObserver((entries) => {
        let maxActiveIndex = -1;

        // Evaluar visibilidad
        timelineItems.forEach((item, index) => {
            const rect = item.getBoundingClientRect();
            // Si el elemento ha entrado más allá de un tercio del viewport
            if (rect.top < window.innerHeight * 0.85) {
                item.classList.add('timeline-active');
                const node = item.querySelector('.timeline-node');
                if (node) {
                    node.classList.remove('border-slate-900');
                    node.classList.add('border-theme-primary', 'bg-theme-primary', 'shadow-[0_0_10px_var(--theme-glow)]');
                }
                if (index > maxActiveIndex) {
                    maxActiveIndex = index;
                }
            } else {
                item.classList.remove('timeline-active');
                const node = item.querySelector('.timeline-node');
                if (node) {
                    node.classList.remove('border-theme-primary', 'bg-theme-primary', 'shadow-[0_0_10px_var(--theme-glow)]');
                    node.classList.add('border-slate-900');
                }
            }
        });

        // Actualizar porcentaje de la barra de progreso
        if (progressBar) {
            if (maxActiveIndex !== -1) {
                const percent = ((maxActiveIndex + 1) / timelineItems.length) * 100;
                progressBar.style.scaleY = (percent / 100).toString();
            } else {
                progressBar.style.scaleY = '0';
            }
        }
    }, observerOptions);

    // Escuchar el evento de scroll en lugar de solo observar la entrada/salida para suavidad
    window.addEventListener('scroll', () => {
        // Ejecutar trigger simulado de la función del observador
        timelineObserver.observe(timelineItems[0]);
    });
    
    // Ejecutar una vez al inicio
    setTimeout(() => {
        timelineObserver.observe(timelineItems[0]);
    }, 200);

    // ==========================================
    // Formulario de Contacto (Formspree / Web3Forms)
    // ==========================================
    const CONTACT_SERVICE = 'formspree'; // 'formspree' o 'web3forms'
    const SERVICE_KEY = 'xkoevzyq'; // Reemplazar con el ID/Key correspondiente
    
    const contactForm = document.getElementById('contact-form') as HTMLFormElement;
    const contactSubmitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
    const contactStatus = document.getElementById('contact-status');

    contactForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!contactStatus || !contactSubmitBtn) return;
        
        contactStatus.className = "hidden text-xs p-3.5 rounded-xl border font-mono";
        contactStatus.innerHTML = "";
        
        if (SERVICE_KEY === 'YOUR_KEY_HERE') {
            contactStatus.classList.remove('hidden');
            contactStatus.classList.add('border-amber-500/30', 'text-amber-400', 'bg-amber-950/20');
            contactStatus.innerHTML = `⚠️ <strong>¡El formulario está maquetado!</strong><br/>Para empezar a recibir correos reales en tu email:
            <ol class="list-decimal pl-4 mt-2 space-y-1">
                <li>Registrate gratis en <a href="https://formspree.io" target="_blank" class="underline hover:text-white font-bold">Formspree.io</a>.</li>
                <li>Crea un formulario nuevo y copia el <strong>Form ID</strong> (ej: <code>xqkrpeoz</code>).</li>
                <li>Abre el archivo <code>src/pages/index.astro</code>, ve a la línea final del script y reemplaza <code>'YOUR_KEY_HERE'</code> con tu Form ID.</li>
            </ol>`;
            return;
        }

        // Efecto de carga en botón
        const originalBtnHTML = contactSubmitBtn.innerHTML;
        contactSubmitBtn.disabled = true;
        contactSubmitBtn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> ${currentLang === 'en' ? 'Sending message...' : 'Enviando mensaje...'}`;

        // Recolectar datos
        const formData = new FormData(contactForm);
        const data: Record<string, string> = {};
        formData.forEach((value, key) => {
            data[key] = value.toString();
        });

        // Endpoint dinámico
        const endpoint = CONTACT_SERVICE === 'web3forms'
            ? 'https://api.web3forms.com/submit'
            : `https://formspree.io/f/${SERVICE_KEY}`;

        // Añadir Access Key si se usa Web3Forms
        if (CONTACT_SERVICE === 'web3forms') {
            data['access_key'] = SERVICE_KEY;
        }

        try {
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                contactStatus.classList.remove('hidden');
                contactStatus.classList.add('border-emerald-500/30', 'text-emerald-400', 'bg-emerald-950/20');
                contactStatus.innerHTML = currentLang === 'en' 
                    ? `✅ Message sent successfully! Ignacio will respond as soon as possible.` 
                    : `✅ ¡Mensaje enviado con éxito! Ignacio te responderá lo antes posible.`;
                contactForm.reset();
            } else {
                throw new Error('Form submission response not ok');
            }
        } catch (error) {
            console.error(error);
            contactStatus.classList.remove('hidden');
            contactStatus.classList.add('border-rose-500/30', 'text-rose-400', 'bg-rose-950/20');
            contactStatus.innerHTML = currentLang === 'en'
                ? `❌ An error occurred while sending the message. Please try again or write directly to <a href="mailto:trkmicignacio@gmail.com" class="underline font-bold text-white hover:text-theme-primary">trkmicignacio@gmail.com</a>.`
                : `❌ Ocurrió un error al enviar el mensaje. Por favor, intenta de nuevo o escríbeme directamente a <a href="https://mail.google.com/mail/?view=cm&fs=1&to=trkmicignacio@gmail.com" target="_blank" rel="noopener noreferrer" class="underline font-bold text-white hover:text-theme-primary">trkmicignacio@gmail.com</a>.`;
        } finally {
            contactSubmitBtn.disabled = false;
            contactSubmitBtn.innerHTML = originalBtnHTML;
        }
    });
</script>

