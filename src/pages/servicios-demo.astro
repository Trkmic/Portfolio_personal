            query_results: "Resultados de la Consulta",
            query_no_searched: "No se ha realizado ninguna búsqueda aún.",
            calc_title: "Calcular Precio Final de un Servicio"
        },
        en: {
            back_btn: "← Back to home",
            page_title: "Hosting & Gastronomy Simulator",
            page_subtitle: "Interactive Java OOP Business Logic Ported to the Web",
            poo_struct: "OOP Class Diagram Structure",
            tab_services: "Services",
            tab_add: "Add New",
            tab_query: "Queries",
            tab_calculate: "Calculate Price",
            list_title: "List of Registered Services",
            add_title: "Register New Service",
            form_type: "Service Type",
            type_gastronomy: "Gastronomy",
            type_hosting: "Hosting",
            form_code: "Service Code (Exact 6 Chars)",
            form_name: "Service Name / Description",
            form_price_gastronomy: "Base Price ($)",
            form_price_hosting: "Price per Night ($)",
            form_date: "Acquisition Date",
            form_promo: "Is in Promotion?",
            form_discount_pct: "Discount Percentage (0 - 100%)",
            form_day_desc: "Weekly Discount Day",
            form_nights: "Number of Nights Reserved",
            form_submit: "Create and Save Service",
            query_title: "Query the Services System",
            query_code_lbl: "Enter Service Code (6 Characters)",
            query_promo_lbl: "Filter by Promotion State",
            query_results: "Query Results",
            query_no_searched: "No query has been executed yet.",
            calc_title: "Calculate Service's Final Price"
        }
    };

    function translateDemoPage(lang) {
        const dict = demoTranslations[lang] || demoTranslations.es;
        const elements = document.querySelectorAll('[data-demo-i18n]');
        elements.forEach(el => {
            const key = el.getAttribute('data-demo-i18n');
            if (key && dict[key]) {
                el.innerHTML = dict[key];
            }
        });

        // Update form labels
        const serviceTypeRad = document.querySelector('input[name="serviceType"]:checked') as HTMLInputElement | null;
        if (labelPrice && serviceTypeRad) {
            if (serviceTypeRad.value === 'gastronomia') {
                labelPrice.textContent = dict.form_price_gastronomy;
            } else {
                labelPrice.textContent = dict.form_price_hosting;
            }
        }
    }

    // Set initial language
    let activeLang = (localStorage.getItem('language') || 'es') as 'es' | 'en';
    translateDemoPage(activeLang);

    // Listen to global changes
    window.addEventListener('language-changed', (e: any) => {
        activeLang = e.detail.language;
        translateDemoPage(activeLang);
    });
</script>

