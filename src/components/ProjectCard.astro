---
// ProjectCard.astro
interface Props {
  titulo: string;
  descripcion: string;
  tags: string[];
  linkGithub: string;
  linkWeb?: string;
  slug: string;
}

const { titulo, descripcion, tags, linkGithub, linkWeb, slug } = Astro.props;

// Extraer el nombre del repositorio de la URL de GitHub de Ignacio (Trkmic)
const repoName = linkGithub.includes('github.com/Trkmic/') 
  ? linkGithub.split('github.com/Trkmic/')[1]?.replace(/\/$/, '')
  : null;
---

<div 
  class="project-card group p-6 rounded-2xl bg-black border border-slate-900 hover:border-theme-primary/50 transition-all duration-300 hover:shadow-[0_0_20px_var(--theme-glow)] flex flex-col justify-between"
  data-tags={tags.map(t => t.toLowerCase()).join(',')}
>
  <div>
    <div class="flex justify-between items-start mb-3">
      <h3 
        class="text-xl font-bold text-white group-hover:text-theme-primary transition-colors font-mono"
        data-i18n={`project_${slug}_title`}
      >
        {titulo}
      </h3>
      
      <div class="flex gap-4 text-xl shrink-0">
        {linkWeb && linkWeb !== "#" && (
          <a 
            href={linkWeb} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-theme-primary hover:text-white transition-all transform hover:scale-125"
            title="Ver sitio en vivo"
            data-i18n-title="project_view_live"
          >
            <i class="fa-solid fa-link"></i>
          </a>
        )}
        
        <a 
          href={linkGithub} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-slate-600 hover:text-theme-primary transition-all transform hover:scale-125"
          title="Ver repositorio en GitHub"
          data-i18n-title="project_view_github"
        >
          <i class="fa-brands fa-github"></i>
        </a>
      </div>
    </div>
    
    <p 
      class="text-slate-500 text-sm leading-relaxed mb-4"
      data-i18n={`project_${slug}_desc`}
    >
      {descripcion}
    </p>
  </div>
  
  <div class="space-y-4 mt-auto">
    <!-- Tags del Stack -->
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="text-[10px] px-2.5 py-1 rounded-md bg-theme-primary/5 text-theme-primary border border-theme-primary/20 font-bold uppercase tracking-tight">
          {tag}
        </span>
      ))}
    </div>

    <!-- Sección de Estadísticas de GitHub en Vivo (Se muestra vía JS) -->
    {repoName && (
      <div 
        class="github-stats-container mt-4 pt-3 border-t border-slate-900 flex flex-wrap gap-4 text-[11px] font-mono text-slate-500 hidden"
        data-repo={repoName}
      >
        <span class="flex items-center gap-1.5" title="Estrellas en GitHub">
          <i class="fa-solid fa-star text-amber-500/80"></i>
          <span class="stars-count">0</span>
        </span>
        <span class="flex items-center gap-1.5" title="Bifurcaciones (Forks)">
          <i class="fa-solid fa-code-branch text-theme-primary/80"></i>
          <span class="forks-count">0</span>
        </span>
        <span class="flex items-center gap-1.5 ml-auto" title="Última actualización">
          <i class="fa-solid fa-clock text-slate-600"></i>
          <span class="commit-date">--/--</span>
        </span>
      </div>
    )}
  </div>
</div>
