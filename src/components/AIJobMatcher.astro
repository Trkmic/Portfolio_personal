---
// AIJobMatcher.astro
---

<section class="bg-slate-950/40 p-6 sm:p-8 rounded-2xl border border-theme-secondary/50 shadow-[inset_0_0_20px_rgba(16,185,129,0.02)] space-y-6">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-xl bg-theme-primary/10 flex items-center justify-center text-theme-primary border border-theme-primary/20">
      <i class="fa-solid fa-sparkles text-lg"></i>
    </div>
    <div>
      <h2 class="text-xl font-bold text-white font-mono">AI Job Matcher</h2>
      <p class="text-xs text-theme-primary font-mono uppercase tracking-wider" data-i18n="matcher_subtitle">Analizador de compatibilidad con ofertas de empleo</p>
    </div>
  </div>

  <p class="text-sm text-slate-400 leading-relaxed" data-i18n="matcher_desc">
    ¿Eres reclutador? Pega aquí la descripción del puesto de trabajo o los requisitos tecnológicos y nuestro analizador inteligente evaluará qué tan bien se adapta Ignacio al puesto, destacando sus fortalezas y proyectos clave.
  </p>

  <div class="space-y-4">
    <textarea 
      id="job-description-input" 
      rows="4" 
      placeholder="Ej: Buscamos un desarrollador Fullstack con conocimientos en NestJS, Angular y TypeScript para integrar APIs y bases de datos..." 
      class="w-full bg-black border border-theme-secondary/40 rounded-xl p-3.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-theme-primary/50 font-sans resize-none transition-colors"
      data-i18n-placeholder="matcher_placeholder"
    ></textarea>

    <button 
      id="analyze-job-btn"
      class="w-full bg-theme-primary hover:bg-theme-primary/90 text-black font-black py-3 rounded-xl transition-all shadow-[0_0_15px_var(--theme-glow)] hover:shadow-[0_0_25px_var(--theme-glow)] uppercase tracking-tight flex justify-center items-center gap-2 cursor-pointer"
    >
      <i class="fa-solid fa-wand-magic-sparkles"></i> <span data-i18n="matcher_btn">Analizar Compatibilidad</span>
    </button>
  </div>

  <!-- Contenedor de Resultados (Oculto por defecto) -->
  <div id="matcher-results" class="hidden border-t border-theme-secondary/30 pt-6 space-y-6 animate-fadeIn">
    <div class="flex flex-col sm:flex-row items-center gap-6 bg-black/40 p-5 rounded-2xl border border-theme-secondary/40">
      <!-- Círculo de porcentaje -->
      <div class="relative w-28 h-28 flex items-center justify-center shrink-0">
        <svg class="w-full h-full transform -rotate-90">
          <circle 
            cx="56" 
            cy="56" 
            r="48" 
            class="stroke-slate-900 fill-none" 
            stroke-width="8"
          />
          <circle 
            id="matcher-progress-circle" 
            cx="56" 
            cy="56" 
            r="48" 
            class="stroke-theme-primary fill-none transition-all duration-1000 ease-out" 
            stroke-width="8"
            stroke-dasharray="301.6"
            stroke-dashoffset="301.6"
          />
        </svg>
        <span id="matcher-percentage" class="absolute text-2xl font-black text-white font-mono">0%</span>
      </div>

      <div class="space-y-2 text-center sm:text-left">
        <h3 id="match-verdict" class="text-lg font-bold text-theme-primary font-mono"></h3>
        <p id="match-summary-text" class="text-sm text-slate-300 leading-relaxed"></p>
      </div>
    </div>

    <!-- Fortalezas y proyectos clave -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="bg-black/20 p-5 rounded-xl border border-theme-secondary/20">
        <h4 class="text-xs font-bold text-theme-primary font-mono uppercase tracking-wider mb-3 flex items-center gap-2" data-i18n="matcher_title_matching">
          <i class="fa-solid fa-list-check"></i> Tecnologías Coincidentes
        </h4>
        <div id="matched-skills-tags" class="flex flex-wrap gap-1.5">
          <!-- Tags dinámicos -->
        </div>
      </div>

      <div class="bg-black/20 p-5 rounded-xl border border-theme-secondary/20">
        <h4 class="text-xs font-bold text-theme-primary font-mono uppercase tracking-wider mb-3 flex items-center gap-2" data-i18n="matcher_title_projects">
          <i class="fa-solid fa-folder-open"></i> Proyectos Sugeridos
        </h4>
        <ul id="suggested-projects-list" class="space-y-2 text-xs text-slate-300">
          <!-- Items dinámicos -->
        </ul>
      </div>
    </div>

    <!-- Carta de Pitch de IA -->
    <div id="ai-pitch-card" class="bg-theme-bg-accent border border-theme-secondary/30 rounded-xl p-5 space-y-2 hidden">
      <div class="flex items-center gap-2 text-xs text-theme-primary font-mono font-bold uppercase tracking-wider" data-i18n="matcher_title_pitch">
        <i class="fa-solid fa-robot"></i> Análisis de Ajuste de IA
      </div>
      <p id="ai-pitch-content" class="text-sm text-slate-300 leading-relaxed whitespace-pre-line italic">
        <!-- Generado dinámicamente -->
      </p>
    </div>
  </div>
</section>

<script>
  // Estructura de tecnologías de Ignacio para match local
  const SKILLS_MAP: Record<string, string[]> = {
    'python': ['python', 'pygame', 'movies', 'película', 'backend'],
    'java': ['java', 'poo', 'hospedaje', 'gastronomia', 'objetos'],
    'javascript': ['javascript', 'js', 'node', 'express', 'web', 'frontend'],
    'typescript': ['typescript', 'ts', 'angular', 'nestjs'],
    'angular': ['angular', 'frontend', 'spa', 'componentes'],
    'nestjs': ['nestjs', 'nest', 'backend', 'api', 'jwt', 'auth'],
    'supabase': ['supabase', 'base de datos', 'realtime', 'chat'],
    'mongodb': ['mongodb', 'mongo', 'nosql'],
    'sql': ['sql', 'base de datos', 'relacional', 'postgres', 'mysql'],
    'astro': ['astro', 'portfolio', 'estatico', 'html', 'css']
  };

  const PROJECTS_DATA = {
    es: [
      { titulo: "Red social (NestJS / Angular)", tags: ["NestJS", "Angular", "MongoDB", "TypeScript"], description: "Plataforma social completa, APIs backend, autenticación JWT, Cloudinary, Chart.js." },
      { titulo: "Sala de juegos (Supabase / Express)", tags: ["Supabase", "TypeScript", "Express", "Angular"], description: "Juegos, chats en tiempo real, base de datos integrada y auth." },
      { titulo: "Organique - E-commerce de Frutas (SQL / JS / Express)", tags: ["JavaScript", "HTML", "CSS", "SQL", "NodeJS", "Express"], description: "E-commerce premium de frutas orgánicas, creador de ensaladas interactivo, dashboard nutricional en Canvas y pasarela de pago." },
      { titulo: "Servicio de hospedaje y gastronomia (Java POO)", tags: ["Java"], description: "Lógica avanzada orientada a objetos en Java, algoritmos de cálculo de tarifas." },
      { titulo: "Gestor de Inventario & IA (Spring Boot / SQL)", tags: ["Java", "Spring Boot", "SQL"], description: "Sistema ERP corporativo, control de stock, compras con reglas de negocio y estimaciones con Gemini AI." },
      { titulo: "Gestion de peliculas (Python CSV)", tags: ["Python"], description: "Análisis y ordenamiento de estructuras de datos masivas." }
    ],
    en: [
      { titulo: "Social Network (NestJS / Angular)", tags: ["NestJS", "Angular", "MongoDB", "TypeScript"], description: "Complete social platform, backend APIs, JWT authentication, Cloudinary, Chart.js." },
      { titulo: "Game Room (Supabase / Express)", tags: ["Supabase", "TypeScript", "Express", "Angular"], description: "Games, real-time chats, integrated database, and auth." },
      { titulo: "Organique - Fruit E-commerce (SQL / JS / Express)", tags: ["JavaScript", "HTML", "CSS", "SQL", "NodeJS", "Express"], description: "Premium organic fruit e-commerce with a virtual fruit salad builder, nutrition dashboard in Canvas, and a payment gateway." },
      { titulo: "Hosting & Gastronomy Service (Java OOP)", tags: ["Java"], description: "Advanced object-oriented logic in Java, rate calculation algorithms." },
      { titulo: "Inventory Manager & AI (Spring Boot / SQL)", tags: ["Java", "Spring Boot", "SQL"], description: "Corporate ERP system, stock control, purchase transactions with business rules, and Gemini AI estimations." },
      { titulo: "Movie Management (Python CSV)", tags: ["Python"], description: "Analysis and sorting of massive data structures." }
    ]
  };

  const analyzeBtn = document.getElementById('analyze-job-btn') as HTMLButtonElement;
  const resultsContainer = document.getElementById('matcher-results');
  const jobInput = document.getElementById('job-description-input') as HTMLTextAreaElement;
  const progressCircle = document.getElementById('matcher-progress-circle') as unknown as SVGCircleElement;
  const percentageLabel = document.getElementById('matcher-percentage');
  const verdictLabel = document.getElementById('match-verdict');
  const summaryLabel = document.getElementById('match-summary-text');
  const skillsContainer = document.getElementById('matched-skills-tags');
  const projectsList = document.getElementById('suggested-projects-list');
  const aiPitchCard = document.getElementById('ai-pitch-card');
  const aiPitchContent = document.getElementById('ai-pitch-content');

  // Idioma activo
  let currentLang = localStorage.getItem('language') || 'es';

  // Escuchar cambio de idioma
  window.addEventListener('language-changed', (e: any) => {
    currentLang = e.detail.language;
  });

  analyzeBtn?.addEventListener('click', async () => {
    const text = jobInput.value.trim();
    if (!text) {
      alert(currentLang === 'en' ? 'Please enter a job description to analyze.' : 'Por favor, ingresa una descripción de empleo para analizar.');
      return;
    }

    // Efecto de carga en botón
    const originalText = analyzeBtn.innerHTML;
    analyzeBtn.disabled = true;
    analyzeBtn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> ${currentLang === 'en' ? 'Analyzing offer...' : 'Analizando oferta...'}`;

    // Procesar localmente primero
    const matchedSkills = new Set<string>();
    const lowercaseText = text.toLowerCase();

    // Buscar coincidencias de palabras clave
    Object.entries(SKILLS_MAP).forEach(([skill, keywords]) => {
      keywords.forEach(kw => {
        if (lowercaseText.includes(kw)) {
          matchedSkills.add(skill);
        }
      });
    });

    // Calcular score dinámico
    let score = 0;
    if (matchedSkills.size > 0) {
      score = 75 + (matchedSkills.size * 6);
      if (lowercaseText.includes('backend') || lowercaseText.includes('fullstack') || lowercaseText.includes('programador') || lowercaseText.includes('developer') || lowercaseText.includes('desarrollador')) {
        score += 8;
      }
      if (lowercaseText.includes('ingles') || lowercaseText.includes('english')) {
        score += 5;
      }
      if (score > 98) score = 98;
    } else {
      score = 45;
      if (lowercaseText.includes('backend') || lowercaseText.includes('fullstack') || lowercaseText.includes('programador') || lowercaseText.includes('developer') || lowercaseText.includes('desarrollador')) {
        score += 6;
      }
      if (lowercaseText.includes('ingles') || lowercaseText.includes('english')) {
        score += 4;
      }
    }

    // Determinar veredicto e idioma
    let verdict = "";
    let summary = "";
    const isEn = currentLang === 'en';

    if (matchedSkills.size > 0) {
      if (score >= 85) {
        verdict = isEn ? "Excellent Compatibility! 🚀" : "¡Excelente Compatibilidad! 🚀";
        const skillsList = Array.from(matchedSkills).map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(', ');
        summary = isEn
          ? `Ignacio covers key technologies required for this role (such as ${skillsList}). His projects demonstrate mastery and immediate practical implementation in these areas.`
          : `Ignacio cubre tecnologías clave requeridas para este puesto (como ${skillsList}). Sus proyectos demuestran dominio e implementación práctica inmediata en estas áreas.`;
      } else {
        verdict = isEn ? "Solid Compatibility 👍" : "Compatibilidad Sólida 👍";
        const skillsList = Array.from(matchedSkills).map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(', ');
        summary = isEn
          ? `Ignacio has matching experience and practical skills in role-related tools like ${skillsList}. His solid academic background and versatility will facilitate quick integration.`
          : `Ignacio cuenta con coincidencia y experiencia práctica en herramientas del puesto como ${skillsList}. Su sólida formación y versatilidad facilitarán una integración rápida.`;
      }
    } else {
      verdict = isEn ? "Adaptability Potential 🌱" : "Potencial de Adaptación 🌱";
      summary = isEn
        ? "Although the offer targets technologies outside his usual stack, Ignacio's solid university training at UTN, combined with his strong foundations in Object-Oriented Programming (OOP), logical design, and a B2 English level (FCE), guarantee rapid adaptability and capacity to transition to the new required stack."
        : "Aunque la oferta se orienta a tecnologías fuera de su stack habitual, la sólida preparación universitaria de Ignacio en la UTN, junto con sus firmes bases en Programación Orientada a Objetos (POO), diseño lógico y un nivel de inglés B2 (FCE), garantizan una rápida adaptabilidad y capacidad de migración hacia el nuevo stack requerido.";
    }

    // Generar tags coincidentes en UI
    if (skillsContainer) {
      skillsContainer.innerHTML = '';
      if (matchedSkills.size > 0) {
        matchedSkills.forEach(skill => {
          const capitalized = skill.charAt(0).toUpperCase() + skill.slice(1);
          skillsContainer.innerHTML += `
            <span class="text-[10px] px-2 py-1 rounded bg-theme-primary/10 text-theme-primary border border-theme-primary/20 font-bold font-mono uppercase">
              ${capitalized}
            </span>
          `;
        });
      } else {
        skillsContainer.innerHTML = isEn
          ? `<span class="text-slate-600 text-xs italic">No explicit technology matches detected, but applies to general development logic.</span>`
          : `<span class="text-slate-600 text-xs italic">Ninguna coincidencia explícita detectada, pero aplica para lógica general de desarrollo.</span>`;
      }
    }

    // Sugerir proyectos en UI
    if (projectsList) {
      projectsList.innerHTML = '';
      let suggestedCount = 0;
      const currentProjects = isEn ? PROJECTS_DATA.en : PROJECTS_DATA.es;

      currentProjects.forEach((proj, idx) => {
        // Enlazar usando los tags originales en minúscula
        const originalProj = PROJECTS_DATA.es[idx];
        const matchesProject = originalProj.tags.some(tag => matchedSkills.has(tag.toLowerCase()));
        if (matchesProject || (suggestedCount < 2 && matchedSkills.size === 0)) {
          suggestedCount++;
          projectsList.innerHTML += `
            <li class="flex items-start gap-2 bg-slate-950 p-2.5 rounded-lg border border-theme-secondary/30">
              <span class="text-theme-primary mt-0.5"><i class="fa-solid fa-circle-check"></i></span>
              <div>
                <strong class="text-white block">${proj.titulo}</strong>
                <span class="text-[11px] text-slate-500">${proj.description}</span>
              </div>
            </li>
          `;
        }
      });
      if (suggestedCount === 0) {
        projectsList.innerHTML = isEn
          ? `<li class="text-slate-600 italic">No specific projects, but it is recommended to review his Social Network.</li>`
          : `<li class="text-slate-600 italic">No hay proyectos específicos, pero se recomienda revisar su Red Social.</li>`;
      }
    }

    // Comprobar si hay clave de Gemini API para análisis con IA avanzado
    const apiKey = localStorage.getItem('gemini_api_key');
    if (apiKey && aiPitchCard && aiPitchContent) {
      aiPitchCard.classList.remove('hidden');
      aiPitchContent.innerHTML = `<span class="text-slate-500"><i class="fa-solid fa-spinner animate-spin"></i> ${isEn ? 'Generating custom pitch with Gemini...' : 'Generando pitch personalizado con Gemini...'}</span>`;

      try {
        const geminiPitch = await queryGeminiForJobFit(text, apiKey, score);
        aiPitchContent.innerHTML = geminiPitch;
      } catch (err) {
        console.error(err);
        aiPitchContent.innerHTML = isEn
          ? `Could not connect to the Gemini API for advanced analysis. However, his calculated general compatibility is ${score}%.`
          : `No se pudo conectar con Gemini API para el análisis avanzado. Sin embargo, su compatibilidad general calculada es de ${score}%.`;
      }
    } else {
      aiPitchCard?.classList.add('hidden');
    }

    // Mostrar contenedor de resultados
    resultsContainer?.classList.remove('hidden');

    // Animación de círculo de progreso
    setTimeout(() => {
      if (progressCircle) {
        const radius = progressCircle.r.baseVal.value;
        const circumference = 2 * Math.PI * radius;
        const offset = circumference - (score / 100) * circumference;
        progressCircle.style.strokeDashoffset = offset.toString();
      }
      
      let currentVal = 0;
      const interval = setInterval(() => {
        if (currentVal >= score) {
          clearInterval(interval);
        } else {
          currentVal++;
          if (percentageLabel) percentageLabel.textContent = `${currentVal}%`;
        }
      }, 10);
    }, 100);

    // Actualizar veredicto y texto descriptivo
    if (verdictLabel) verdictLabel.textContent = verdict;
    if (summaryLabel) summaryLabel.textContent = summary;

    // Scroll suave hasta los resultados
    resultsContainer?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    // Restablecer botón
    analyzeBtn.disabled = false;
    analyzeBtn.innerHTML = originalText;
  });

  // Llamada a Gemini para el Fit Checker
  async function queryGeminiForJobFit(jobText: string, key: string, calculatedScore: number): Promise<string> {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${key}`;
    
    const cvInfoEs = `
      Nombre: Ignacio Trkmic Torres
      Estudios: UTN Avellaneda (Tecnicatura Universitaria en Programación a 2 materias de recibirse, Ingeniería Mecánica comenzando en 2026).
      Idiomas: Inglés B2 First Certificate.
      Stack: Python, Java, JavaScript, TypeScript, Angular, NestJS, Supabase, MongoDB, SQL, Astro.
      Proyectos:
      - Red social (NestJS, Angular, JWT, MongoDB): Dashboard, multimedia con Cloudinary, charts.
      - Sala de juegos (Supabase, Angular, Express): Chat tiempo real, auth, hosting Vercel.
      - Organique - E-commerce de Frutas (JS, NodeJS, Express, SQL/SQLite/MySQL): Creador de ensaladas interactivo, dashboard nutricional en Canvas, pasarela de pago, bases de datos MySQL/SQLite.
      - Servicio de hospedaje y gastronomia (Java POO): Sistema de gestión de tarifas de turismo.
      - Gestor de Inventario & IA (Java, Spring Boot, SQL, H2): Control de stock, compras con reglas de negocio y estimaciones predictivas con Gemini AI.
      - Gestion de peliculas (Python CSV): Estructuras de datos, ordenamientos, reportes.
    `;

    const cvInfoEn = `
      Name: Ignacio Trkmic Torres
      Education: UTN Avellaneda (Assoc. Degree in Programming, 2 subjects away from graduation; Mechanical Engineering starting in 2026).
      Languages: B2 English level, First Certificate passed.
      Stack: Python, Java, JavaScript, TypeScript, Angular, NestJS, Supabase, MongoDB, SQL, Astro.
      Projects:
      - Social Network (NestJS, Angular, JWT, MongoDB): Dashboard, multimedia with Cloudinary, charts.
      - Game Room (Supabase, Angular, Express): Real-time chat, auth, hosting on Vercel.
      - Organique - Fruit E-commerce (JS, NodeJS, Express, SQL/SQLite/MySQL): Virtual fruit salad builder, Canvas nutrition dashboard, payment gateway, MySQL/SQLite DB.
      - Hosting & Gastronomy Service (Java OOP): Tourism rate management system.
      - Inventory Manager & AI (Java, Spring Boot, SQL, H2): Stock control, purchase transactions with business rules, and predictive Gemini AI estimations.
      - Movie Management (Python CSV): Data structures, sorting, and reporting.
    `;

    const isEn = currentLang === 'en';
    const cvInfo = isEn ? cvInfoEn : cvInfoEs;

    const requestPrompt = isEn
      ? `You are an expert IT recruitment consultant.
          
         Given the candidate's profile:
         ${cvInfo}

         And the job offer description:
         "${jobText}"

         Calculated compatibility percentage: ${calculatedScore}%.

         Write a short and persuasive analysis (maximum 3 short paragraphs) in English addressed to the recruiter explaining:
         1. Why Ignacio would fit the role well based on his specific projects (explicitly cite which of his projects demonstrate the required knowledge).
         2. His key strengths (UTN technical education and B2 English FCE).
         3. A brief and friendly final recommendation.

         Use emojis to structure ideas in an appealing and modern way.`
      : `Eres un consultor experto en reclutamiento de tecnología. 
          
         Dado el perfil del candidato Ignacio Torres:
         ${cvInfo}

         Y la siguiente oferta laboral:
         "${jobText}"

         Porcentaje de compatibilidad calculado: ${calculatedScore}%.

         Escribe un análisis corto y persuasivo (máximo 3 párrafos cortos) en español dirigido al reclutador que explica:
         1. Por qué Ignacio se adaptaría bien al puesto basado en sus proyectos específicos (cita explícitamente qué proyectos de él demuestran el conocimiento requerido).
         2. Sus puntos fuertes clave (formación técnica en UTN y nivel de inglés FCE).
         3. Una recomendación final breve y amigable.

         Usa emojis para estructurar las ideas de forma agradable y moderna.`;

    const requestBody = {
      contents: [{
        parts: [{
          text: requestPrompt
        }]
      }],
      generationConfig: {
        maxOutputTokens: 400,
        temperature: 0.6
      }
    };

    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(requestBody)
    });

    if (!response.ok) throw new Error('Gemini API Error');
    const data = await response.json();
    return data.candidates[0].content.parts[0].text;
  }
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
