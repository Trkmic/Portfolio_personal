  // LLamada a Gemini API
  async function queryGemini(promptText: string): Promise<string> {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`;

    const cvContextEs = `
      Información del desarrollador:
      Nombre: Ignacio Trkmic Torres.
      Edad: 20 años.
      Ubicación: Buenos Aires, Argentina.
      Estudios: Cursa la UTN Avellaneda. Tecnicatura Universitaria en Programación (a 2 materias del título, periodo 2024-2026) e Ingeniería Mecánica (comenzando en 2026).
      Inglés: Nivel B2 aprobado (First Certificate in English). Estudió en English Time (2018-2024).
      Contacto: Correo: trkmicignacio@gmail.com, LinkedIn: ${CV_DATA.contacto.linkedin}, GitHub: ${CV_DATA.contacto.github}.
      Tecnologías: Python, Java, JavaScript, TypeScript, HTML, CSS, Angular, React, Expo, SQL, MongoDB, Astro, NestJS, Supabase, Vercel.
      Proyectos:
      1. "Red social": backend NestJS, frontend Angular, autenticación JWT, gráficos de estadísticas con Chart.js, gestión de multimedia en Cloudinary. GitHub: https://github.com/Trkmic/red-social, Web: https://red-social-sage.vercel.app/
      2. "Sala de juegos": Angular, Supabase, Express, chat grupal en tiempo real, base de datos y despliegue en Vercel. GitHub: https://github.com/Trkmic/sala-de-juegos, Web: https://sala-de-juegos-tau.vercel.app/home
      3. "Tienda Online": E-commerce premium de frutas orgánicas ("Organique") con creador de ensaladas, dashboard nutricional interactivo en Canvas, pasarela de pago y bases de datos MySQL/SQLite. GitHub: https://github.com/Trkmic/freshmarket-ecommerce, Web: https://freshmarket-ecommerce.onrender.com
      4. "Servicio de hospedaje y gastronomia": Escrito en Java utilizando Programación Orientada a Objetos para la administración de servicios turísticos. GitHub: https://github.com/Trkmic/servicio_hospedaje_gatronomia
      5. "Gestor de Inventario & IA": Sistema ERP corporativo desarrollado en Java Spring Boot con JPA, H2 y Gemini AI. Control de stock, compras con cálculo dinámico de precio y pronóstico predictivo de inventario. GitHub: https://github.com/Trkmic/inventory-management-api
      6. "Gestion de peliculas": Procesador de datos en Python para ordenar catálogos en CSV y generar reportes. GitHub: https://github.com/Trkmic/Gestion_peliculas

      Instrucciones de Personalidad:
      - Eres "IgnacIA", la IA asistente personal de Ignacio Torres.
      - Habla de manera profesional, cercana, entusiasta y convincente para reclutadores de talento de desarrollo de software.
      - Escribe en español latino de forma concisa. No des respuestas gigantescas de más de 3 párrafos.
      - Si te preguntan algo que no tiene nada que ver con Ignacio o programación, dile amablemente que estás entrenada para hablar del perfil técnico de Ignacio, pero intenta relacionarlo si es posible.
      - Usa formato Markdown con emojis para que las respuestas sean visualmente estructuradas y fáciles de leer.
    `;

    const cvContextEn = `
      Developer information:
      Name: Ignacio Trkmic Torres.
      Age: 20 years old.
      Location: Buenos Aires, Argentina.
      Studies: Enrolled at UTN Avellaneda. University Higher Technical Degree in Programming (2 subjects away from graduation, 2024-2026) and Mechanical Engineering (starting in 2026).
      English: Approved B2 level (First Certificate in English). Studied at English Time (2018-2024).
      Contact: Email: trkmicignacio@gmail.com, LinkedIn: ${CV_DATA.contacto.linkedin}, GitHub: ${CV_DATA.contacto.github}.
      Technologies: Python, Java, JavaScript, TypeScript, HTML, CSS, Angular, React, Expo, SQL, MongoDB, Astro, NestJS, Supabase, Vercel.
      Projects:
      1. "Social Network": NestJS backend, Angular frontend, JWT auth, stats graphs with Chart.js, multimedia with Cloudinary. GitHub: https://github.com/Trkmic/red-social, Web: https://red-social-sage.vercel.app/
      2. "Game Room": Angular, Supabase, Express, real-time group chat, integrated DB & Auth, Vercel. GitHub: https://github.com/Trkmic/sala-de-juegos, Web: https://sala-de-juegos-tau.vercel.app/home
      3. "Online Store": Premium organic fruit e-commerce ("Organique") with a virtual fruit salad builder, native Canvas nutrition dashboard, payment gateway, and MySQL/SQLite database. GitHub: https://github.com/Trkmic/freshmarket-ecommerce, Web: https://freshmarket-ecommerce.onrender.com
      4. "Hosting & Gastronomy Service": Written in Java using OOP for tourism and hotel service administration. GitHub: https://github.com/Trkmic/servicio_hospedaje_gatronomia
      5. "Inventory Manager & AI": Corporate ERP system built in Java Spring Boot with JPA, H2, and Gemini AI. Stock management, purchase transactions with dynamic pricing, and predictive inventory forecasting. GitHub: https://github.com/Trkmic/inventory-management-api
      6. "Movie Management": Python data processor to sort catalogs in CSV and generate reports. GitHub: https://github.com/Trkmic/Gestion_peliculas

      Personality Instructions:
      - You are "IgnacIA", Ignacio Torres's personal assistant AI.
      - Speak professionally, closely, enthusiastically, and convincingly for software development talent recruiters.
      - Write in English in a concise manner. Do not give massive responses over 3 paragraphs.
      - If they ask you about something unrelated to Ignacio or programming, politely tell them that you are trained to talk about Ignacio's technical profile, but try to connect it if possible.
      - Use Markdown format with emojis to keep responses visually structured and easy to read.
    `;

    const cvContext = currentLang === 'en' ? cvContextEn : cvContextEs;
    const requestText = currentLang === 'en'
      ? `Context about Ignacio:\n${cvContext}\n\nUser Question:\n${promptText}`
      : `Contexto sobre Ignacio:\n${cvContext}\n\nPregunta del usuario:\n${promptText}`;

    const requestBody = {
      contents: [{
        parts: [{
          text: requestText
        }]
      }],
      generationConfig: {
        maxOutputTokens: 500,
        temperature: 0.7
      }
    };

    const response = await fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(requestBody)
    });

    if (!response.ok) {
      throw new Error('Error al llamar a la API de Gemini');
    }

    const data = await response.json();
    return data.candidates[0].content.parts[0].text;
  }

  // Manejar envío de mensaje
  async function handleUserMessage(messageText: string) {
    if (!messageText.trim()) return;

    // Mostrar mensaje del usuario
    addMessage('user', messageText);
    chatInput.value = '';

    // Mostrar indicador de escritura
    const typingIndicator = showTypingIndicator();

    try {
      let botResponse = '';
      if (apiKey) {
        // Consultar con Gemini si hay API Key configurada
        botResponse = await queryGemini(messageText);
      } else {
        // Responder con NLP local
        await new Promise(resolve => setTimeout(resolve, 800)); // Simular retraso natural
        botResponse = getLocalResponse(messageText);
      }

      // Remover indicador y agregar mensaje del bot
      typingIndicator?.remove();
      addMessage('bot', botResponse);
    } catch (error) {
      console.error(error);
      typingIndicator?.remove();
      const errorMsg = currentLang === 'en'
        ? `Sorry, an error occurred while processing your request with the Gemini AI server. Could you please check your API Key or try again in a few moments?\n\n*Note*: You can continue chatting in Local Mode by deleting the API Key from settings.`
        : `Lo siento, ocurrió un error al procesar tu solicitud con el servidor de IA de Gemini. ¿Podrías verificar tu API Key o intentar de nuevo en unos momentos?\n\n*Nota*: Puedes seguir chateando en Modo Local borrando la API Key de la configuración.`;
      addMessage('bot', errorMsg);
    }
  }

  chatForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    handleUserMessage(chatInput.value);
  });

  // Manejar sugerencias rápidas
  suggestionBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const prompt = btn.textContent?.trim() || '';
      handleUserMessage(prompt);
    });
  });
</script>
