---
// AIChatbot.astro
---

<div class="fixed bottom-6 right-6 z-50 font-sans">
  <!-- Botón flotante -->
  <button 
    id="chat-toggle-btn"
    class="w-14 h-14 rounded-full bg-theme-primary hover:scale-110 text-black flex items-center justify-center shadow-[0_0_20px_var(--theme-glow)] hover:shadow-[0_0_30px_var(--theme-glow)] transition-all duration-300 cursor-pointer group"
    aria-label="Abrir chat con IA"
    data-i18n-title="chatbot_toggle_title"
  >
    <span class="relative flex h-3 w-3 absolute -top-1 -right-1">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-theme-primary opacity-75"></span>
      <span class="relative inline-flex rounded-full h-3 w-3 bg-theme-primary"></span>
    </span>
    <i class="fa-solid fa-robot text-2xl group-hover:rotate-12 transition-transform"></i>
  </button>

  <!-- Ventana de Chat -->
  <div 
    id="chat-window" 
    class="hidden absolute bottom-18 right-0 w-[350px] sm:w-[400px] h-[500px] flex flex-col rounded-2xl border border-theme-primary/20 bg-slate-950/95 backdrop-blur-xl shadow-[0_0_40px_var(--theme-glow)] overflow-hidden transition-all duration-300 scale-95 origin-bottom-right"
  >
    <!-- Cabecera -->
    <div class="bg-gradient-to-r from-theme-bg/50 to-slate-950 px-4 py-3 flex items-center justify-between border-b border-theme-secondary/30">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full bg-theme-primary/10 flex items-center justify-center text-theme-primary border border-theme-primary/20">
          <i class="fa-solid fa-robot text-sm"></i>
        </div>
        <div>
          <h3 class="font-bold text-white text-sm font-mono flex items-center gap-1.5">
            IgnacIA
            <span class="w-2 h-2 rounded-full bg-theme-primary animate-pulse"></span>
          </h3>
          <span class="text-[10px] text-theme-secondary font-medium" data-i18n="chatbot_status">Asistente de Ignacio</span>
        </div>
      </div>
      
      <div class="flex items-center gap-2">
        <!-- Botón Configuración (API Key) -->
        <button 
          id="chat-settings-btn"
          class="text-slate-500 hover:text-theme-primary transition-colors p-1.5 rounded-lg hover:bg-slate-900 cursor-pointer"
          title="Configurar Gemini API Key"
          data-i18n-title="chatbot_settings_title"
        >
          <i class="fa-solid fa-gear"></i>
        </button>
        <!-- Botón Cerrar -->
        <button 
          id="chat-close-btn"
          class="text-slate-500 hover:text-rose-400 transition-colors p-1.5 rounded-lg hover:bg-slate-900 cursor-pointer"
          title="Cerrar Chat"
          data-i18n-title="chatbot_close_title"
        >
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
    </div>

    <!-- Panel de Configuración (Oculto por defecto) -->
    <div id="chat-settings-panel" class="hidden bg-slate-900/90 border-b border-theme-secondary/20 p-4 text-xs space-y-3">
      <p class="text-slate-400" data-i18n="chatbot_settings_panel_desc">
        Por defecto, utilizo un <strong>procesador local inteligente</strong>. Para hablar de forma libre e ilimitada conmigo, ingresa una clave de API de Gemini:
      </p>
      <div class="flex gap-2">
        <input 
          type="password" 
          id="gemini-key-input" 
          placeholder="AIzaSy..." 
          class="flex-1 bg-black border border-theme-secondary/50 rounded-lg px-2.5 py-1.5 text-white font-mono placeholder-slate-600 focus:outline-none focus:border-theme-primary/50"
        />
        <button 
          id="save-key-btn" 
          class="bg-theme-primary hover:bg-theme-primary/95 text-black font-bold px-3 py-1.5 rounded-lg transition-colors cursor-pointer"
          data-i18n="chatbot_settings_panel_save"
        >
          Guardar
        </button>
      </div>
      <div class="flex justify-between items-center text-[10px] text-slate-500">
        <span data-i18n="chatbot_settings_panel_footer">Tu clave se guarda localmente en tu navegador.</span>
        <button id="clear-key-btn" class="text-rose-500 hover:underline hidden cursor-pointer" data-i18n="chatbot_settings_panel_clear">Borrar clave</button>
      </div>
    </div>

    <!-- Mensajes -->
    <div 
      id="chat-messages" 
      class="flex-1 overflow-y-auto p-4 space-y-4 scrollbar-thin scrollbar-thumb-theme-secondary scrollbar-track-transparent"
    >
      <!-- Mensaje Inicial -->
      <div class="flex items-start gap-2.5">
        <div class="w-7 h-7 rounded-full bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 border border-theme-primary/20">
          <i class="fa-solid fa-robot text-xs"></i>
        </div>
        <div class="flex flex-col gap-1 max-w-[85%]">
          <div class="bg-theme-bg-accent border border-theme-secondary/30 text-slate-300 rounded-2xl px-3.5 py-2 text-sm leading-relaxed" data-i18n="chatbot_greeting">
            ¡Hola! Soy <strong>IgnacIA</strong>, la asistente virtual de Ignacio Trkmic Torres. 
            <br/><br/>
            ¿En qué te puedo ayudar hoy? Puedes preguntarme sobre su experiencia, estudios, tecnologías o formas de contacto.
          </div>
          <span class="text-[9px] text-slate-600 self-start font-mono">IgnacIA • <span data-i18n="chatbot_local_now">Ahora</span></span>
        </div>
      </div>
    </div>

    <!-- Sugerencias Rápidas -->
    <div id="chat-suggestions" class="px-4 py-2 flex flex-wrap gap-1.5 border-t border-theme-secondary/10 bg-slate-950">
      <button class="suggestion-btn text-[11px] px-2.5 py-1 rounded-full bg-slate-900 hover:bg-theme-bg/30 text-theme-primary hover:text-theme-primary border border-theme-secondary/30 hover:border-theme-primary/30 transition-all cursor-pointer" data-i18n="chatbot_suggest_projects">
        ¿Qué proyectos tiene?
      </button>
      <button class="suggestion-btn text-[11px] px-2.5 py-1 rounded-full bg-slate-900 hover:bg-theme-bg/30 text-theme-primary hover:text-theme-primary border border-theme-secondary/30 hover:border-theme-primary/30 transition-all cursor-pointer" data-i18n="chatbot_suggest_studies">
        ¿Cuáles son sus estudios?
      </button>
      <button class="suggestion-btn text-[11px] px-2.5 py-1 rounded-full bg-slate-900 hover:bg-theme-bg/30 text-theme-primary hover:text-theme-primary border border-theme-secondary/30 hover:border-theme-primary/30 transition-all cursor-pointer" data-i18n="chatbot_suggest_english">
        ¿Nivel de inglés?
      </button>
      <button class="suggestion-btn text-[11px] px-2.5 py-1 rounded-full bg-slate-900 hover:bg-theme-bg/30 text-theme-primary hover:text-theme-primary border border-theme-secondary/30 hover:border-theme-primary/30 transition-all cursor-pointer" data-i18n="chatbot_suggest_contact">
        ¿Cómo contactarlo?
      </button>
    </div>

    <!-- Formulario de Envío -->
    <form 
      id="chat-form" 
      class="p-3 border-t border-theme-secondary/30 bg-black flex gap-2"
    >
      <input 
        type="text" 
        id="chat-input" 
        placeholder="Pregúntame algo..." 
        autocomplete="off"
        class="flex-1 bg-slate-950 border border-theme-secondary/50 rounded-xl px-3.5 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-theme-primary/50"
        data-i18n-placeholder="chatbot_input_placeholder"
      />
      <button 
        type="submit" 
        class="w-9 h-9 rounded-xl bg-theme-primary hover:bg-theme-primary/90 text-black flex items-center justify-center transition-colors cursor-pointer"
        aria-label="Enviar mensaje"
        data-i18n-title="chatbot_send_title"
      >
        <i class="fa-solid fa-paper-plane text-sm"></i>
      </button>
    </form>
  </div>
</div>

<script>
  // Base de datos de Ignacio en formato estructurado para el chatbot local
  const CV_DATA = {
    nombre: "Ignacio Trkmic Torres",
    edad: 20,
    ubicacion: "Buenos Aires, Argentina",
    estudios: "Estudiante de la Tecnicatura Universitaria en Programación (a 2 materias de recibirse) e Ingeniería Mecánica en la UTN Avellaneda.",
    ingles: "Nivel B2 de inglés (First Certificate aprobado). Estudió 6 años en la cultural English Time (2018-2024).",
    contacto: {
      email: "trkmicignacio@gmail.com",
      linkedin: "https://linkedin.com/in/ignacio-trkmic-5a797827a/",
      github: "https://github.com/Trkmic"
    },
    stack: [
      "Python", "Java", "JavaScript", "TypeScript", "HTML", "CSS", 
      "Angular", "React", "Expo", "SQL", "MongoDB", "Astro", "NestJS", "Supabase", "Vercel"
    ],
    proyectos: [
      {
        titulo: "Red social",
        descripcion: "Plataforma social completa con NestJS y Angular. Cuenta con autenticación JWT, gráficos de estadísticas con Chart.js y gestión de fotos con Cloudinary.",
        url: "https://github.com/Trkmic/red-social",
        web: "https://red-social-sage.vercel.app/"
      },
      {
        titulo: "Sala de juegos",
        descripcion: "Plataforma con varios juegos en línea con sistema de perfiles de usuarios y chat grupal en tiempo real. Utiliza Supabase y Express.",
        url: "https://github.com/Trkmic/sala-de-juegos",
        web: "https://sala-de-juegos-tau.vercel.app/home"
      },
      {
        titulo: "Organique - E-commerce de Frutas",
        descripcion: "E-commerce premium de frutas orgánicas con creador de ensaladas interactivo, dashboard nutricional en Canvas y pasarela de pago vinculada a base de datos MySQL/SQLite.",
        url: "https://github.com/Trkmic/freshmarket-ecommerce",
        web: "https://freshmarket-ecommerce.onrender.com"
      },
      {
        titulo: "Servicio de hospedaje y gastronomia",
        descripcion: "Sistema en Java basado en POO orientado a la administración de servicios turísticos y hotelería.",
        url: "https://github.com/Trkmic/servicio_hospedaje_gatronomia"
      },
      {
        titulo: "Gestor de Inventario & IA",
        descripcion: "Sistema ERP corporativo desarrollado en Java Spring Boot con JPA, H2 y Gemini AI. Permite el control de stock, compras con cálculo dinámico de precio y pronóstico predictivo de inventario.",
        url: "https://github.com/Trkmic/inventory-management-api"
      },
      {
        titulo: "Gestion de peliculas",
        descripcion: "Aplicación de consola en Python para procesar grandes volúmenes de datos usando archivos CSV/JSON y algoritmos de ordenamiento avanzados.",
        url: "https://github.com/Trkmic/Gestion_peliculas"
      }
    ]
  };

  // Selectores de DOM
  const chatToggleBtn = document.getElementById('chat-toggle-btn');
  const chatWindow = document.getElementById('chat-window');
  const chatCloseBtn = document.getElementById('chat-close-btn');
  const chatForm = document.getElementById('chat-form') as HTMLFormElement;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const chatMessages = document.getElementById('chat-messages');
  const chatSettingsBtn = document.getElementById('chat-settings-btn');
  const chatSettingsPanel = document.getElementById('chat-settings-panel');
  const geminiKeyInput = document.getElementById('gemini-key-input') as HTMLInputElement;
  const saveKeyBtn = document.getElementById('save-key-btn');
  const clearKeyBtn = document.getElementById('clear-key-btn');
  const suggestionBtns = document.querySelectorAll('.suggestion-btn');

  // Idioma activo del chatbot
  let currentLang = localStorage.getItem('language') || 'es';

  // Cargar clave de API guardada
  let apiKey = localStorage.getItem('gemini_api_key') || '';
  if (apiKey) {
    geminiKeyInput.value = apiKey.substring(0, 6) + '...';
    clearKeyBtn?.classList.remove('hidden');
  }

  // Escuchar cambio de idioma
  window.addEventListener('language-changed', (e: any) => {
    currentLang = e.detail.language;
  });

  // Toggle Ventana Chat
  chatToggleBtn?.addEventListener('click', () => {
    chatWindow?.classList.toggle('hidden');
    if (!chatWindow?.classList.contains('hidden')) {
      chatInput?.focus();
      chatWindow.style.transform = 'scale(1)';
    } else {
      chatWindow.style.transform = 'scale(0.95)';
    }
  });

  chatCloseBtn?.addEventListener('click', () => {
    chatWindow?.classList.add('hidden');
    chatWindow.style.transform = 'scale(0.95)';
  });

  // Toggle Panel Configuración
  chatSettingsBtn?.addEventListener('click', () => {
    chatSettingsPanel?.classList.toggle('hidden');
  });

  // Guardar clave API
  saveKeyBtn?.addEventListener('click', () => {
    const key = geminiKeyInput.value.trim();
    if (key) {
      if (key.includes('...')) {
        // No cambiar si es el valor enmascarado
        return;
      }
      localStorage.setItem('gemini_api_key', key);
      apiKey = key;
      alert(currentLang === 'en' ? 'Gemini API Key saved successfully.' : 'Clave de Gemini API guardada con éxito.');
      chatSettingsPanel?.classList.add('hidden');
      clearKeyBtn?.classList.remove('hidden');
    }
  });

  // Borrar clave API
  clearKeyBtn?.addEventListener('click', () => {
    localStorage.removeItem('gemini_api_key');
    apiKey = '';
    geminiKeyInput.value = '';
    clearKeyBtn?.classList.add('hidden');
    alert(currentLang === 'en' ? 'API Key deleted. Using local processor.' : 'Clave borrada. Usando procesador local.');
  });

  // Función para añadir mensaje a la UI
  function addMessage(sender: 'user' | 'bot', text: string) {
    if (!chatMessages) return;

    const messageDiv = document.createElement('div');
    messageDiv.className = sender === 'user' ? 'flex items-start gap-2.5 justify-end' : 'flex items-start gap-2.5';

    const timestamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

    if (sender === 'user') {
      const youText = currentLang === 'en' ? 'You' : 'Tú';
      messageDiv.innerHTML = `
        <div class="flex flex-col gap-1 max-w-[85%] items-end">
          <div class="bg-theme-primary text-black font-semibold rounded-2xl px-3.5 py-2 text-sm leading-relaxed">
            ${escapeHTML(text)}
          </div>
          <span class="text-[9px] text-slate-600 font-mono">${youText} • ${timestamp}</span>
        </div>
      `;
    } else {
      const botName = 'IgnacIA';
      const nowLabel = currentLang === 'en' ? 'Now' : 'Ahora';
      messageDiv.innerHTML = `
        <div class="w-7 h-7 rounded-full bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 border border-theme-primary/20">
          <i class="fa-solid fa-robot text-xs"></i>
        </div>
        <div class="flex flex-col gap-1 max-w-[85%]">
          <div class="bg-slate-900/40 border border-theme-secondary/20 text-slate-300 rounded-2xl px-3.5 py-2 text-sm leading-relaxed whitespace-pre-line">
            ${text}
          </div>
          <span class="text-[9px] text-slate-600 font-mono">${botName} • ${nowLabel}</span>
        </div>
      `;
    }

    chatMessages.appendChild(messageDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  // Sanitizador de texto
  function escapeHTML(str: string) {
    return str.replace(/[&<>'"]/g, 
      tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
    );
  }

  // Efecto Cargando / Escribiendo
  function showTypingIndicator() {
    if (!chatMessages) return null;
    const typingDiv = document.createElement('div');
    typingDiv.id = 'typing-indicator';
    typingDiv.className = 'flex items-start gap-2.5';
    typingDiv.innerHTML = `
      <div class="w-7 h-7 rounded-full bg-theme-primary/10 flex items-center justify-center text-theme-primary shrink-0 border border-theme-primary/20">
        <i class="fa-solid fa-robot text-xs"></i>
      </div>
      <div class="bg-slate-900/30 border border-theme-secondary/20 text-slate-400 rounded-2xl px-3.5 py-2 text-sm flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 bg-theme-primary rounded-full animate-bounce" style="animation-delay: 0ms"></span>
        <span class="w-1.5 h-1.5 bg-theme-primary rounded-full animate-bounce" style="animation-delay: 150ms"></span>
        <span class="w-1.5 h-1.5 bg-theme-primary rounded-full animate-bounce" style="animation-delay: 300ms"></span>
      </div>
    `;
    chatMessages.appendChild(typingDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return typingDiv;
  }

  // Procesador Local NLP
  function getLocalResponse(query: string): string {
    // Normalizar texto: minúsculas, sin acentos/diacríticos y sin signos de interrogación
    const q = query.toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[¿?¡!]/g, "")
      .trim();

    const isEn = currentLang === 'en';

    if (isEn) {
      // English Local NLP
      if (q.includes('project') || q.includes('portfolio') || q.includes('creat') || q.includes('make') || q.includes('built') || q.includes('done') || q.includes('develop')) {
        let response = `Ignacio has developed several high-quality projects in NestJS, Angular, Supabase, Python, and Java. Here are the main ones:\n\n`;
        
        const enProjDesc: Record<string, string> = {
          "Red social": "Complete social platform with NestJS and Angular. Features JWT authentication, stats charts with Chart.js, and photo management with Cloudinary.",
          "Sala de juegos": "Online gaming suite with user profiles and real-time group chat. Uses Supabase and Express.",
          "Tienda Online": "Premium organic fruit e-commerce with a virtual fruit salad builder, dynamic nutrition dashboard in Canvas, and a payment gateway connected to a MySQL/SQLite database.",
          "Servicio de hospedaje y gastronomia": "Java system based on OOP principles, designed for tourism and hotel service administration.",
          "Gestor de Inventario & IA": "Corporate ERP system built in Java Spring Boot with JPA, H2, and Gemini AI. Features stock management, purchase transactions with dynamic pricing, and predictive inventory forecasting.",
          "Gestion de peliculas": "Python console application to process large datasets using CSV/JSON files and advanced sorting algorithms."
        };
        const enTitle: Record<string, string> = {
          "Red social": "Social Network",
          "Sala de juegos": "Game Room",
          "Tienda Online": "Organique - Fruit E-commerce",
          "Servicio de hospedaje y gastronomia": "Hosting & Gastronomy Service",
          "Gestor de Inventario & IA": "Inventory Manager & AI",
          "Gestion de peliculas": "Movie Management"
        };
        
        CV_DATA.proyectos.forEach(p => {
          response += `🌐 **${enTitle[p.titulo] || p.titulo}**: ${enProjDesc[p.titulo] || p.descripcion}\n`;
          response += `   *Links:* [GitHub](${p.url})`;
          if (p.web) response += ` | [Live Web](${p.web})`;
          response += `\n\n`;
        });
        return response;
      }

      if (q.includes('stud') || q.includes('utn') || q.includes('universi') || q.includes('educa') || q.includes('engineer') || q.includes('programer') || q.includes('degree') || q.includes('title')) {
        return `Ignacio is studying at the **National Technological University (UTN) Regional Avellaneda**:\n\n• 💻 **University Higher Technical Degree in Programming**: Currently enrolled, only 2 subjects away from graduation (2024-2026).\n• ⚙️ **Mechanical Engineering**: Starting his studies in 2026.\n\nHe has an excellent blend of systems logic and physical/mechanical fundamentals.`;
      }

      if (q.includes('english') || q.includes('language') || q.includes('first') || q.includes('b2') || q.includes('fce')) {
        return `Ignacio has a certified **B2 English level (passed First Certificate in English)**.\n\nHe studied for 6 years (2018-2024) at the prestigious cultural institute *English Time*, enabling him to work fluently in multicultural teams and read advanced technical documentation without issues.`;
      }

      if (q.includes('contact') || q.includes('email') || q.includes('mail') || q.includes('write') || q.includes('social') || q.includes('linkedin') || q.includes('phone') || q.includes('github')) {
        return `You can easily reach Ignacio through the following channels:\n\n• 📧 **Email**: [trkmicignacio@gmail.com](https://mail.google.com/mail/?view=cm&fs=1&to=trkmicignacio@gmail.com)\n• 💼 **LinkedIn**: [linkedin.com/in/ignacio-trkmic-5a797827a](${CV_DATA.contacto.linkedin})\n• 🐙 **GitHub**: [github.com/Trkmic](${CV_DATA.contacto.github})\n\nFeel free to write! He is open to new career opportunities and internships.`;
      }

      if (q.includes('skill') || q.includes('stack') || q.includes('techno') || q.includes('know') || q.includes('program') || q.includes('language') || q.includes('angular') || q.includes('react') || q.includes('expo') || q.includes('nestjs') || q.includes('python') || q.includes('java')) {
        return `Ignacio's tech stack includes:\n\n• **Languages**: Python, Java, JavaScript, TypeScript, HTML, and CSS.\n• **Frameworks & Libraries**: Angular, React, Expo, NestJS, Astro, Express, Pygame.\n• **Database & Cloud**: SQL, MongoDB, Supabase, Cloudinary, Vercel.\n\n*Tip*: You can click on any of these icons in the 'Tech Stack' section of the page to automatically filter related projects.`;
      }

      if (q.includes('hello') || q.includes('hi') || q.includes('greet') || q.includes('hey') || q.includes('morning') || q.includes('afternoon') || q.includes('evening')) {
        return `Hi! I am IgnacIA, a chatbot programmed to answer questions about Ignacio Trkmic Torres's career path. What would you like to know about him?\n\n- His latest **projects**.\n- His **studies** at UTN.\n- His **English** level.\n- **Contact** info.`;
      }

      return `I understood your question in a limited way with my local NLP module. \n\nIgnacio has solid experience in backend (NestJS, Java, Python) and frontend (Angular, Astro, Tailwind CSS). \n\n*Tip*: To chat with me freely and intelligently about any topic, you can enter a **Gemini API** key by clicking on the gear icon ⚙️ in the chat header.`;
    } else {
      // Spanish Local NLP
      if (q.includes('proyec') || q.includes('portafolio') || q.includes('creado') || q.includes('hecho') || q.includes('hizo') || q.includes('desarrollado')) {
        let response = `Ignacio ha desarrollado varios proyectos de gran nivel en NestJS, Angular, Supabase, Python y Java. Aquí tienes los principales:\n\n`;
        CV_DATA.proyectos.forEach(p => {
          response += `🌐 **${p.titulo}**: ${p.descripcion}\n`;
          response += `   *Enlaces:* [GitHub](${p.url})`;
          if (p.web) response += ` | [Web en Vivo](${p.web})`;
          response += `\n\n`;
        });
        return response;
      }

      if (q.includes('estud') || q.includes('utn') || q.includes('universi') || q.includes('educa') || q.includes('ingenieria') || q.includes('programador') || q.includes('tecnicatura') || q.includes('titulo')) {
        return `Ignacio se está formando en la **Universidad Tecnológica Nacional (UTN) Regional Avellaneda**:\n\n• 💻 **Tecnicatura Universitaria en Programación**: Actualmente se encuentra cursando y le faltan únicamente 2 materias para obtener el título (2024-2026).\n• ⚙️ **Ingeniería Mecánica**: Iniciando su cursada en 2026.\n\nPosee una excelente combinación de lógica de sistemas y fundamentos físicos/mecánicos.`;
      }

      if (q.includes('ingles') || q.includes('idioma') || q.includes('first') || q.includes('b2') || q.includes('english') || q.includes('fce')) {
        return `Ignacio posee un nivel de inglés **B2 (FCE - First Certificate in English aprobado)**.\n\nSe formó durante 6 años (2018-2024) en el prestigioso instituto cultural *English Time*, lo cual le capacita para trabajar de manera fluida en equipos multiculturales y leer documentación técnica avanzada sin problemas.`;
      }

      if (q.includes('contact') || q.includes('email') || q.includes('correo') || q.includes('escrib') || q.includes('redes') || q.includes('linkedin') || q.includes('telefono') || q.includes('github') || q.includes('mail')) {
