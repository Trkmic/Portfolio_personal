---
// ThemeSwitcher.astro
---

<div class="fixed top-6 right-6 z-50 flex items-center gap-2">
  <div class="bg-slate-950/85 backdrop-blur-md border border-slate-900 px-3.5 py-2 rounded-full flex gap-3.5 items-center shadow-[0_4px_25px_rgba(0,0,0,0.6)]">
    <!-- Icono de paleta -->
    <span class="text-slate-500 text-xs font-mono select-none"><i class="fa-solid fa-palette"></i></span>
    
    <!-- Botón Emerald -->
    <button 
      class="theme-btn w-4 h-4 rounded-full bg-emerald-500 hover:scale-125 transition-transform cursor-pointer border border-white/20 active:scale-95" 
      data-theme="theme-emerald"
      title="Tema Emerald (Matrix)"
      data-i18n-title="theme_emerald"
    ></button>

    <!-- Botón Cyberpunk -->
    <button 
      class="theme-btn w-4 h-4 rounded-full bg-rose-500 hover:scale-125 transition-transform cursor-pointer border border-white/20 active:scale-95" 
      data-theme="theme-cyberpunk"
      title="Tema Cyberpunk"
      data-i18n-title="theme_cyberpunk"
    ></button>

    <!-- Botón Dracula -->
    <button 
      class="theme-btn w-4 h-4 rounded-full bg-purple-500 hover:scale-125 transition-transform cursor-pointer border border-white/20 active:scale-95" 
      data-theme="theme-dracula"
      title="Tema Dracula"
      data-i18n-title="theme_dracula"
    ></button>

    <!-- Separador -->
    <span class="w-[1px] h-4 bg-slate-800 select-none"></span>

    <!-- Botón de Abrir Terminal Hacker -->
    <button 
      id="terminal-toggle" 
      class="text-slate-500 hover:text-theme-primary hover:scale-115 transition-all cursor-pointer font-bold text-[13px] active:scale-95" 
      title="Abrir terminal hacker (>_)"
      data-i18n-title="theme_terminal"
    >
      <i class="fa-solid fa-terminal"></i>
    </button>

    <!-- Botón de Mute/Volumen -->
    <button 
      id="volume-toggle" 
      class="text-slate-500 hover:scale-115 transition-all cursor-pointer text-[13px] active:scale-95 w-4 flex justify-center" 
      title="Silenciar / Activar sonidos de la web"
      data-i18n-title="theme_mute"
    >
      <i class="fa-solid fa-volume-xmark" id="volume-icon"></i>
    </button>

    <!-- Separador -->
    <span class="w-[1px] h-4 bg-slate-800 select-none"></span>

    <!-- Botón de Idioma -->
    <button 
      id="lang-toggle" 
      class="text-slate-500 hover:text-theme-primary hover:scale-115 transition-all cursor-pointer font-extrabold text-[10px] font-mono active:scale-95 w-6 h-6 rounded-full flex items-center justify-center border border-slate-900 bg-slate-950/40"
      title="Cambiar idioma / Switch language"
      data-i18n-title="theme_lang"
    >
      EN
    </button>
  </div>
</div>

<!-- Script en línea para evitar el parpadeo de color al cargar -->
<script is:inline>
  (function () {
    const savedTheme = localStorage.getItem('theme') || 'theme-emerald';
    const savedMode = localStorage.getItem('theme-mode') || 'dark';
    document.documentElement.className = `${savedTheme} ${savedMode === 'light' ? 'light' : ''} scroll-smooth`;
    const savedLang = localStorage.getItem('language') || 'es';
    const langBtn = document.getElementById('lang-toggle');
    if (langBtn) {
      langBtn.textContent = savedLang === 'es' ? 'EN' : 'ES';
    }
  })();
</script>

<script>
  import { playChirp, playBeep } from '../utils/audioHelper';

  const themeButtons = document.querySelectorAll('.theme-btn');
  const termBtn = document.getElementById('terminal-toggle');
  const volBtn = document.getElementById('volume-toggle');
  const volIcon = document.getElementById('volume-icon');
  const langBtn = document.getElementById('lang-toggle');

  // Inicializar Mute en true por defecto si no existe
  if (localStorage.getItem('muted') === null) {
    localStorage.setItem('muted', 'true');
  }

  // Inicializar Idioma en es por defecto si no existe
  if (localStorage.getItem('language') === null) {
    localStorage.setItem('language', 'es');
  }

  function updateLangUI() {
    const currentLang = localStorage.getItem('language') || 'es';
    if (langBtn) {
      langBtn.textContent = currentLang === 'es' ? 'EN' : 'ES';
    }
    document.documentElement.lang = currentLang;
  }

  updateLangUI();

  langBtn?.addEventListener('click', () => {
    const currentLang = localStorage.getItem('language') || 'es';
    const newLang = currentLang === 'es' ? 'en' : 'es';
    localStorage.setItem('language', newLang);
    updateLangUI();
    
    // Despachar evento global
    window.dispatchEvent(new CustomEvent('language-changed', {
      detail: { language: newLang }
    }));
    
    playChirp();
  });

  function applyTheme(themeName: string) {
    document.documentElement.classList.remove('theme-emerald', 'theme-cyberpunk', 'theme-dracula');
    document.documentElement.classList.add(themeName);
    localStorage.setItem('theme', themeName);
    
    // Sonido al cambiar de tema
    playChirp();
  }

  themeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const theme = btn.getAttribute('data-theme');
      if (theme) {
        applyTheme(theme);
      }
    });
  });

  // Evento para abrir la terminal modal
  termBtn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-terminal'));
  });

  // Actualizar UI del altavoz
  function updateVolumeUI() {
    const isMuted = localStorage.getItem('muted') === 'true';
    if (isMuted) {
      volIcon?.classList.remove('fa-volume-high', 'text-theme-primary');
      volIcon?.classList.add('fa-volume-xmark', 'text-slate-500');
    } else {
      volIcon?.classList.remove('fa-volume-xmark', 'text-slate-500');
      volIcon?.classList.add('fa-volume-high', 'text-theme-primary');
    }
  }

  updateVolumeUI();

  // Escuchar clics de volumen
  volBtn?.addEventListener('click', () => {
    const isMuted = localStorage.getItem('muted') === 'true';
    localStorage.setItem('muted', isMuted ? 'false' : 'true');
    updateVolumeUI();
    
    if (isMuted) {
      // Si estaba silenciado y ahora se activó, reproducir sonido de confirmación
      setTimeout(playBeep, 50);
    }
  });
</script>
